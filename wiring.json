{
  "schema": "endgame-ai.wiring.v2",
  "model": {
    "transport": "transport_xai",
    "transport_config": {
      "transport_xai": {
        "mode": "api",
        "model": "grok-4.3",
        "url": "https://api.x.ai/v1/responses",
        "temperature": 0.4,
        "structured_outputs": {
          "enabled": true
        },
        "reasoning": {
          "enabled": false,
          "pattern": "native",
          "extractor": "reasoning_field",
          "effort": "none",
          "injection_template": "REASONING:\n{reasoning}"
        }
      },
      "transport_file_proxy": {
        "request_path": "runtime_request.json",
        "response_path": "runtime_response.json",
        "poll_interval": 0.25,
        "reasoning": {
          "enabled": false,
          "pattern": "native",
          "extractor": "reasoning_field",
          "effort": "none",
          "injection_template": "REASONING:\n{reasoning}"
        }
      }
    },
    "global": {
      "timeout": 180,
      "brain_call_budget": null
    },
    "stable_prefix": {
      "enabled": false,
      "include_in_request": false
    },
    "organs": {
      "plan": {
        "reasoning_effort": "none",
        "max_output_tokens": 6144
      },
      "action_frame": {
        "reasoning_effort": "none",
        "max_output_tokens": 2048
      },
      "execution": {
        "reasoning_effort": "none",
        "max_output_tokens": 4096
      },
      "verification": {
        "reasoning_effort": "none",
        "max_output_tokens": 1024
      },
      "reflection": {
        "reasoning_effort": "none",
        "max_output_tokens": 2048
      },
      "git_evolution_patch": {
        "reasoning_effort": "none",
        "max_output_tokens": 16384
      }
    }
  },
  "paths": {
    "nodes": ".",
    "brains": ".",
    "state": "runtime_state.json",
    "control": "runtime_control.json",
    "event_log": "runtime_events.jsonl",
    "caps": "."
  },
  "control_default": {
    "mode": "run",
    "step_token": 0,
    "updated_at": 0
  },
  "observe_config": {
    "hover_cache": {
      "enabled": true,
      "scan": {
        "step_px": 64,
        "delay_ms": 0,
        "max_subtree_nodes_per_point": 2000,
        "max_total_nodes": 10000
      },
      "filter": {
        "max_elements": 500,
        "max_per_window": 30,
        "max_text": 200,
        "require_interactive": true
      }
    }
  },
  "self_modify": {
    "context_mode": "checked_out_branch",
    "known_good_ref": "refs/endgame/known_good",
    "hot_swap_on_failure": true,
    "execution": {
      "rollback_on_failure": true
    },
    "git": {
      "remote": "origin",
      "push_after_commit": true
    },
    "web_search": {
      "enabled": true,
      "allowed_domains": [
        "github.com"
      ]
    }
  },
  "topology": {
    "cycle_start": "node_observe",
    "nodes": [
      "node_planner",
      "node_scheduler",
      "node_observe",
      "node_execute",
      "node_frame_action",
      "node_verify",
      "node_reflect",
      "node_self_modify",
      "node_satisfied",
      "node_error"
    ],
    "edges": {
      "node_planner": {
        "step_ready": "node_scheduler",
        "reflect": "node_reflect",
        "error": "node_error"
      },
      "node_scheduler": {
        "step_ready": "node_observe",
        "plan_complete": "node_satisfied",
        "error": "node_error"
      },
      "node_observe": {
        "initial_screen": "node_planner",
        "screen_ready": "node_execute",
        "error": "node_error"
      },
      "node_execute": {
        "verify": "node_verify",
        "frame": "node_observe",
        "reflect": "node_reflect",
        "error": "node_error"
      },
      "node_verify": {
        "step_confirmed": "node_scheduler",
        "step_denied": "node_reflect",
        "error": "node_error"
      },
      "node_reflect": {
        "retry": "node_observe",
        "replan": "node_planner",
        "frame": "node_frame_action",
        "escalate": "node_self_modify",
        "give_up": "node_satisfied",
        "topology_patch": "node_self_modify",
        "error": "node_error"
      },
      "node_self_modify": {
        "modified": "node_planner",
        "modify_failed": "node_reflect",
        "error": "node_error"
      },
      "node_satisfied": {
        "halt": "halt"
      },
      "node_error": {
        "planner": "node_planner",
        "reflect": "node_reflect",
        "halt": "halt"
      },
      "node_frame_action": {
        "framed": "node_observe",
        "reflect": "node_reflect",
        "error": "node_error"
      }
    },
    "barriers": {}
  },
  "prompts": {
    "node_planner": "Plan JSON: next_signal step_ready|reflect; intent complete remaining root-goal steps {description,done_when}. No act/code/verify/diagnose.",
    "node_scheduler": "Mechanical: select next step or plan_complete; carry effective_goal.",
    "node_observe": "Mechanical UIA scan: write fresh_observation, desktop_tree_text, action_index, stats.",
    "node_frame_action": "Frame JSON action_frame: next_signal framed|reflect; screen_summary,target,strategy,risk,notes. Narrow execute route.",
    "node_execute": "Execute JSON: EXECUTE=>verify+code; FRAME=>frame empty; CANNOT=>frame|reflect empty. Code runs via exec(code, ns) with local helpers. Capture evidence.",
    "node_verify": "Verify JSON: step_confirmed|step_denied, success, reasoning. Accept real evidence only.",
    "node_reflect": "Reflect JSON: retry|replan|frame|escalate|give_up|topology_patch plus lesson,diagnosis. Task failures route; organism/topology changes self_modify.",
    "node_self_modify": "Self-modify JSON git_evolution_patch: modified plus summary,rationale,read_files,file_writes,file_deletes,wiring_patches,commands,expected_validation. Patch consumed runtime; prefer deletion.",
    "node_satisfied": "Mechanical halt with satisfied only when complete and no last_error.",
    "node_error": "Mechanical recovery to planner, reflect, or halt."
  },
  "fractal": {
    "max_recursion_depth": 3,
    "child_duration_seconds": 60
  }
}
