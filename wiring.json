{
  "schema": "endgame-ai.wiring.v2",
  "model": {
    "transport": "transport_xai",
    "transport_config": {
      "transport_xai": {}
    },
    "global": {},
    "stable_prefix": {
      "enabled": false,
      "include_in_request": false,
      "source": {
        "suffixes": [],
        "names": [],
        "skip_parts": [],
        "skip_prefixes": []
      }
    },
    "organs": {}
  },
  "paths": {
    "nodes": ".",
    "brains": ".",
    "state": "runtime_state.json",
    "control": "runtime_control.json",
    "caps": ".",
    "guidance": "guidance.txt"
  },
  "control_default": {
    "mode": "run",
    "step_token": 0,
    "updated_at": 0
  },
  "observe_config": {
    "hover_cache": {
      "enabled": false,
      "scan": {
        "step_px": 64,
        "delay_ms": 0,
        "max_subtree_nodes_per_point": 1,
        "max_total_nodes": 1
      },
      "filter": {
        "max_elements": 1,
        "max_per_window": 1,
        "max_text": 1,
        "require_interactive": false
      }
    }
  },
  "self_modify": {
    "context_mode": "checked_out_branch",
    "known_good_ref": "refs/endgame/known_good",
    "hot_swap_on_failure": true,
    "execution": {
      "rollback_on_failure": true
    },
    "git": {
      "remote": "origin",
      "push_after_commit": false
    },
    "web_search": {},
    "evolvable": {
      "suffixes": [],
      "names": [],
      "skip_prefixes": [],
      "activation": {
        "immediate": [],
        "next_run": []
      }
    }
  },
  "topology": {
    "cycle_start": "node_guidance:plan",
    "nodes": [
      "node_guidance:plan",
      "node_satisfied"
    ],
    "edges": {
      "node_guidance:plan": {
        "attend": "node_satisfied",
        "error": "node_satisfied"
      },
      "node_satisfied": {
        "halt": "halt"
      }
    },
    "barriers": {}
  },
  "prompts": {
    "node_guidance:plan": "",
    "node_satisfied": "",
    "node_frame_action": ""
  },
  "prompt_aliases": {},
  "shared_prompt_prefix": "",
  "record_contracts": {},
  "capabilities": {
    "schema": "endgame-ai.execute-capabilities.v1",
    "power": "",
    "helpers": {},
    "modules": [],
    "state": [],
    "signals": [],
    "faculties": {}
  },
  "fractal": {
    "max_recursion_depth": 0,
    "child_duration_seconds": 0
  },
  "node_defs": {
    "node_frame_action": {
      "prompt_key": "node_frame_action",
      "expected_record_type": "action_frame",
      "signals": ["framed", "reflect"],
      "signal_source": "data.next_signal",
      "build_payload": {
        "goal": {"path": "state.goal"},
        "step": {
          "description": {"get": {"path": "state.current_step"}, "key": "description", "default": {"path": "state.goal"}},
          "done_when": {"get": {"path": "state.current_step"}, "key": "done_when", "default": ""}
        },
        "focus": {"call": "bus.state_brief", "arg": {"path": "state"}},
        "evidence": {"call": "bus.execution_evidence", "arg": {"path": "state"}},
        "observation": {"call": "bus.observation_brief", "arg": {"path": "state"}}
      },
      "evidence": {"call": "bus.execution_evidence", "arg": {"path": "state"}},
      "patch": {
        "action_frame": {
          "screen_summary": {"path": "data.screen_summary"},
          "target": {"path": "data.target"},
          "strategy": {"path": "data.strategy"},
          "risk": {"path": "data.risk"},
          "notes": {"path": "data.notes"},
          "step_index": {"int": {"path": "state.step"}, "default": 0}
        },
        "framing_attempted_for_step": {"int": {"path": "state.step"}, "default": 0},
        "effective_goal": {
          "narrate": {"path": "state.effective_goal"},
          "line": {"format": "\n\n[FRAME_ACTION] Target {0} via {1}: {2}", "args": [{"path": "data.target"}, {"path": "data.strategy"}, {"path": "data.notes"}]},
          "root": {"path": "state.goal"}
        }
      }
    }
  }
}
