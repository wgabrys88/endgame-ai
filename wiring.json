{
  "schema": "endgame-ai.wiring.v2",
  "topology": {
    "cycle_start": "planner",
    "nodes": ["planner", "scheduler", "observe", "execute", "frame_action", "verify", "reflect", "self_modify", "satisfied", "error"],
    "edges": {
      "planner": {"step_ready": "scheduler", "reflect": "reflect", "error": "error"},
      "scheduler": {"step_ready": "observe", "plan_complete": "satisfied", "error": "error"},
      "observe": {"screen_ready": "execute", "error": "error"},
      "execute": {"verify": "verify", "frame": "frame_action", "reflect": "reflect", "self_modify": "self_modify", "error": "error"},
      "verify": {"step_confirmed": "scheduler", "step_denied": "reflect", "error": "error"},
      "reflect": {"retry": "observe", "replan": "planner", "escalate": "self_modify", "give_up": "satisfied", "error": "error"},
      "self_modify": {"modified": "planner", "modify_failed": "reflect", "error": "error"},
      "satisfied": {"halt": "halt"},
      "error": {"planner": "planner", "reflect": "reflect", "halt": "halt"},
      "frame_action": {"framed": "execute", "reflect": "reflect", "error": "error"}
    }
  },
  "limits": {
    "max_request_chars": 120000,
    "max_observation_chars": 8000,
    "max_workspace_manifest_files": 40,
    "on_violation": "fail_hard"
  },
  "model": {
    "transport": "xai",
    "transport_config": {
      "xai": {
        "mode": "api",
        "api_key_env": "XAI_API_KEY",
        "model": "grok-4.3",
        "url": "https://api.x.ai/v1/responses",
        "temperature": 0.25,
        "structured_outputs": {"enabled": true},
        "reasoning": {"enabled": true, "pattern": "native", "extractor": "reasoning_field"},
        "max_output_tokens": 4096,
        "top_p": 0.95,
        "truncation": "disabled"
      }
    },
    "global": {"timeout": 180, "max_brain_calls": null, "raw_log": true, "raw_log_path": "comms/brain_raw.jsonl", "reasoning_enabled": true},
    "stable_prefix": {"enabled": true, "include_in_request": true, "for_record_types": ["plan", "execution", "verification", "reflection", "action_frame", "git_evolution_patch", "satisfied"], "include_for_record_types": ["plan", "execution", "verification", "reflection", "action_frame", "git_evolution_patch", "satisfied"]},
    "organs": {
      "plan": {"reasoning_effort": "medium", "temperature": 0.35, "max_output_tokens": 2400},
      "action_frame": {"reasoning_effort": "medium", "temperature": 0.45, "max_output_tokens": 2200},
      "execution": {"reasoning_effort": "low", "temperature": 0.25, "max_output_tokens": 5000},
      "verification": {"reasoning_effort": "none", "temperature": 0.05, "max_output_tokens": 1200},
      "reflection": {"reasoning_effort": "medium", "temperature": 0.25, "max_output_tokens": 2400},
      "git_evolution_patch": {"reasoning_effort": "high", "temperature": 0.2, "max_output_tokens": 24000, "timeout": 360, "web_search": {"enabled": true, "allowed_domains": ["github.com", "raw.githubusercontent.com", "api.github.com"]}}
    }
  },
  "paths": {"state": "state.json", "control": "comms/control.json", "runtime_log": "comms/runtime.ndjson", "brain_raw_log": "comms/brain_raw.jsonl"},
  "control_default": {"mode": "run", "step_token": 0, "updated_at": 0},
  "observe_config": {"step_px": 32, "delay_ms": 2, "cell_size": 80, "max_elements": 450, "restore_cursor": true, "max_tree_chars": 8000, "max_windows": 16, "max_semantic_controls": 32, "max_visible_windows": 18},
  "timing": {"post_execute_delay_ms": 3000},
  "reflect_escalation": {"observation_missing_min_streak": 3},
  "self_modify": {
    "context_mode": "checked_out_branch",
    "git": {"remote": "origin", "push_after_commit": true},
    "web_search": {"enabled": true, "allowed_domains": ["github.com", "raw.githubusercontent.com", "api.github.com"]},
    "execution": {"rollback_on_failure": true, "timeout_s": 90},
    "wiring_allowed_new_prefixes": ["self_modify.", "model.stable_prefix.", "model.organs.", "limits.", "prompts."]
  },
  "prompts": {
    "planner": "plan: {next_signal, goal_narration, intent[]}. step_ready|reflect. done_when must cite SEMANTIC_UI roles/zones.",
    "execute": "execution: {conclusion, code}. EXECUTE|CANNOT|FRAME|SELF_MODIFY. Body: pyautogui, click_node(id), scroll_node(id), focus_window, open_url, subprocess. Prefer click_node over raw coords. Set result=. Physical clicks only.",
    "frame_action": "action_frame: {next_signal, screen_summary, target, strategy, risk, notes}. target = SEMANTIC_UI id/role/@x,y.",
    "verify": "verification: {next_signal: step_confirmed|step_denied, success, reasoning}. done_when vs SEMANTIC_UI + last_result/last_error.",
    "reflect": "reflection: {next_signal: retry|replan|escalate|give_up, lesson, diagnosis}. evidence + failure_streak only.",
    "self_modify": "git_evolution_patch: {summary, rationale, read_files[], unified_diffs[], file_writes[], commands[]}. Ground in stable prefix + branch_url. Narrow patches. contract_check must pass.",
    "satisfied": "satisfied: {next_signal: halt}."
  }
}