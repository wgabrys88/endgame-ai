{
  "schema": "endgame-ai.wiring.v1",
  "model": {
    "transport": "xai",
    "transport_config": {
      "openai": {
        "base_url": "http://localhost:1234",
        "path": "/v1/chat/completions",
        "model": "nvidia-nemotron-3-nano-4b",
        "temperature": 0.2,
        "reasoning": {
          "enabled": true,
          "pattern": "two_pass",
          "injection_template": "ROD_REASONING_CONTENT:\n{reasoning}",
          "extractor": "think_tags"
        }
      },
      "opencode": {
        "executable": "%USERPROFILE%/AppData/Local/opencode/opencode-cli.exe",
        "model": "opencode-go/deepseek-v4-flash",
        "extra_args": [],
        "reasoning": {
          "enabled": false
        }
      },
      "xai": {
        "mode": "api",
        "api_key_env": "XAI_API_KEY",
        "model": "grok-build-0.1",
        "url": "https://api.x.ai/v1/responses",
        "temperature": 0.2,
        "reasoning": {
          "enabled": true,
          "pattern": "native",
          "extractor": "reasoning_field"
        }
      },
      "grok_cli": {
        "executable": "grok",
        "extra_args": [],
        "reasoning": {
          "enabled": true,
          "pattern": "native",
          "extractor": "reasoning_field"
        }
      },
      "file_proxy": {
        "request_path": "comms/request.json",
        "response_path": "comms/response.json",
        "poll_interval": 0.25,
        "reasoning": {
          "enabled": true,
          "pattern": "two_pass",
          "injection_template": "ROD_REASONING_CONTENT:\n{reasoning}",
          "extractor": "think_tags"
        }
      },
      "browser_ai": {
        "documented_stub": true,
        "reasoning": {
          "enabled": false
        }
      }
    },
    "global": {
      "timeout": 180,
      "max_brain_calls": null,
      "raw_log": true,
      "reasoning_enabled": true
    }
  },
  "paths": {
    "seed_nodes": "seed_nodes",
    "live_nodes": "live_nodes",
    "seed_brains": "seed_brains",
    "live_brains": "live_brains",
    "state": "state.json",
    "control": "comms/control.json",
    "runtime_log": "comms/runtime.ndjson"
  },
  "control_default": {
    "mode": "run",
    "step_token": 0,
    "updated_at": 0
  },
  "observe_config": {
    "max_depth": 3,
    "include_offscreen": false,
    "max_elements": 500
  },
  "topology": {
    "cycle_start": "planner",
    "nodes": [
      "planner",
      "scheduler",
      "observe",
      "execute",
      "verify",
      "reflect",
      "self_modify",
      "satisfied",
      "error"
    ],
    "edges": {
      "planner": {
        "step_ready": "scheduler",
        "reflect": "reflect",
        "error": "error"
      },
      "scheduler": {
        "step_ready": "observe",
        "plan_complete": "satisfied",
        "error": "error"
      },
      "observe": {
        "screen_ready": "execute",
        "error": "error"
      },
      "execute": {
        "verify": "verify",
        "reflect": "reflect",
        "self_modify": "self_modify",
        "error": "error"
      },
      "verify": {
        "step_confirmed": "scheduler",
        "step_denied": "reflect",
        "error": "error"
      },
      "reflect": {
        "retry": "observe",
        "replan": "planner",
        "escalate": "self_modify",
        "give_up": "satisfied",
        "error": "error"
      },
      "self_modify": {
        "modified": "planner",
        "modify_failed": "reflect",
        "error": "error"
      },
      "satisfied": {
        "halt": "halt"
      },
      "error": {
        "planner": "planner",
        "reflect": "reflect",
        "halt": "halt"
      }
    }
  },
  "prompts": {
    "planner": "You are the planner node of endgame-ai. Return one JSON object with record_type='plan', data.next_signal (must be 'step_ready' or 'reflect'), and data.intent (your plan as a list of steps, each with 'description' and 'done_when').",
    "scheduler": "You are the scheduler node of endgame-ai. Pick the next step from state.plan by index state.step. Return record_type='schedule', data.next_signal ('step_ready' or 'plan_complete'), data.step (the step object or null if complete).",
    "execute": "You are the EXECUTE node. Write Python code to achieve the step goal. You have full access to the Windows desktop via the namespace. Return JSON with record_type='execution', data.code (Python string), data.conclusion ('EXECUTE' or 'CANNOT').",
    "verify": "You are the verify node of endgame-ai. Judge if the step intent was satisfied based on evidence (screen, last_action, last_result, last_error). Return record_type='verification', data.next_signal ('step_confirmed' or 'step_denied'), data.success (boolean).",
    "reflect": "You are the reflect node of endgame-ai. Diagnose failure and choose recovery. Return record_type='reflection', data.next_signal ('retry'|'replan'|'escalate'|'give_up'), data.lesson (concrete diagnosis + specific suggestion).",
    "self_modify": "You are the self-modify node. You may rewrite wiring.json AND write new node files to live_nodes/. Return record_type='wiring_patch', data with wiring_patches, node_writes, node_deletes.",
    "satisfied": "Goal achieved. Return record_type='satisfied', data.next_signal='halt'."
  },
  "action_verbs": {
    "click": "Click at coordinates or on element: {x, y} or {element_id}.",
    "type_text": "Type text into focused element: {text}.",
    "key_press": "Press key combination: {keys: \"ctrl+s\"}.",
    "scroll": "Scroll in focused element: {direction: \"up|down\", amount: 3}.",
    "focus_window": "Focus window by title substring or hwnd.",
    "open_url": "Open URL in browser: {browser, url}.",
    "shell": "Execute shell command: {command: \"cmd\", timeout: 30}.",
    "noop": "Record no operation."
  }
}