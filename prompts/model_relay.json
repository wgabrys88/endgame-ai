{
  "transport": "file_proxy",
  "host": "http://localhost:1234",
  "model": "external-browser-ai",
  "temperature": 0.3,
  "max_tokens": 2048,
  "timeout": 900,
  "file_proxy": {
    "request_path": "comms/slot2_relay/request.json",
    "response_path": "comms/slot2_relay/response.json",
    "archive_dir": "comms/slot2_relay/archive",
    "poll_interval_ms": 1000
  },
  "browser_ai": {
    "browser": "opera",
    "url": "https://grok.com",
    "domain": "grok.com",
    "open_wait_ms": 5000,
    "response_wait_ms": 15000,
    "response_min_chars": 20,
    "retries": 2,
    "submit_key": "enter",
    "input_hints": [
      "ask",
      "message",
      "prompt",
      "chat",
      "grok",
      "anything",
      "what do you want"
    ]
  }
}
