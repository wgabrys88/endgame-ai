{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "endgame-topology/v1",
  "title": "endgame wiring",
  "type": "object",
  "required": ["schema", "topology"],
  "properties": {
    "schema": { "const": "endgame-topology/v1" },
    "instance": {
      "type": "object",
      "properties": {
        "slot": { "type": "integer", "minimum": 0 }
      }
    },
    "topology": {
      "type": "object",
      "required": ["cycle_start", "nodes", "edges"],
      "properties": {
        "cycle_start": { "type": "string", "minLength": 1 },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    },
    "reasoning": { "type": "object" },
    "prompts": { "type": "object" },
    "guards": { "type": "object" },
    "runtime": { "type": "object" },
    "act": { "$ref": "#/$defs/actConfig" },
    "errors": { "type": "object" },
    "limits": {
      "type": "object",
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "max_replans": { "type": "integer", "minimum": 0 },
        "max_cycles": { "type": "integer", "minimum": 1 },
        "history_depth": { "type": "integer", "minimum": 1 },
        "reasoning_chain_depth": { "type": "integer", "minimum": 1 },
        "bus_max": { "type": "integer", "minimum": 1 },
        "planner_retries": { "type": "integer", "minimum": 0 },
        "llm_parse_retries": { "type": "integer", "minimum": 0 },
        "trace_few_shot": { "type": "integer", "minimum": 0 },
        "debug_value_max_chars": { "type": "integer", "minimum": 0 },
        "error_preview_chars": { "type": "integer", "minimum": 0 }
      }
    },
    "verbs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "target_field": { "type": "string" },
          "value_field": { "type": "string" },
          "key_field": { "type": "string" },
          "title_field": { "type": "string" },
          "amount_field": { "type": "string" }
        }
      }
    },
    "context": { "type": "object" },
    "observe": {
      "type": "object",
      "properties": {
        "min_elements": { "type": "integer", "minimum": 0 },
        "wait_retries": { "type": "integer", "minimum": 0 },
        "wait_ms": { "type": "integer", "minimum": 0 },
        "probe_step_px": { "type": "integer", "minimum": 10 },
        "probe_delay_ms": { "type": "integer", "minimum": 0 },
        "hover_scan_enabled": { "type": "boolean" },
        "hover_scan_step_px": { "type": "integer", "minimum": 10 },
        "hover_scan_delay_ms": { "type": "integer", "minimum": 0 },
        "dense_probe_min_px": { "type": "integer", "minimum": 10 },
        "scroll_enrich_min": { "type": "integer", "minimum": 0 },
        "scroll_enrich_passes": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "scroll_enrich_delay_ms": { "type": "integer", "minimum": 0 },
        "read_text_max": { "type": "integer", "minimum": 0 },
        "scope_depth": { "type": "integer", "minimum": 1 },
        "element_text_max": { "type": "integer", "minimum": 0 },
        "render_focused_first": { "type": "boolean" },
        "window_limit": { "type": "integer", "minimum": 1 },
        "desktop_tree_enabled": { "type": "boolean" },
        "desktop_tree_max_depth": { "type": "integer", "minimum": 1 },
        "desktop_tree_max_nodes": { "type": "integer", "minimum": 1 },
        "desktop_tree_child_limit": { "type": "integer", "minimum": 1 },
        "overlay_window_limit": { "type": "integer", "minimum": 1 },
        "window_scan_limit": { "type": "integer", "minimum": 1 },
        "render_class_name": { "type": "boolean" },
        "render_automation_id": { "type": "boolean" },
        "render_window_per_element": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "moe": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "label"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "type": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "circuit": { "type": "string" },
        "prompt": { "$ref": "#/$defs/prompt" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "on"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "on": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": ["id", "phase", "verdict", "description", "match"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "phase": { "enum": ["verify", "act"] },
        "verdict": { "enum": ["confirm", "deny", "reject"] },
        "description": { "type": "string" },
        "match": { "$ref": "#/$defs/ruleMatch" }
      },
      "additionalProperties": false
    },
    "ruleMatch": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "outcome_ok": { "type": "boolean" },
        "outcome_failed": { "type": "boolean" },
        "actions_include_verb": { "type": "string", "minLength": 1 },
        "actions_all_verb": { "type": "string", "minLength": 1 },
        "actions_verb_absent": { "type": "string", "minLength": 1 },
        "actions_sequence": { "$ref": "#/$defs/stringList" },
        "actions_wrote_nonempty": { "type": "boolean" },
        "actions_pressed": { "type": "string", "minLength": 1 },
        "actions_pressed_absent": { "type": "string", "minLength": 1 },
        "actions_hotkey_contains": { "$ref": "#/$defs/stringList" },
        "actions_hotkey_absent": { "$ref": "#/$defs/stringList" },
        "actions_write_is_url": { "type": "boolean" },
        "actions_writes_all_url": { "type": "boolean" },
        "actions_write_target_line_contains": { "$ref": "#/$defs/stringList" },
        "actions_write_target_line_absent": { "$ref": "#/$defs/stringList" },
        "actions_click_target_line_contains": { "$ref": "#/$defs/stringList" },
        "actions_click_target_line_absent": { "$ref": "#/$defs/stringList" },
        "actions_focus_target_matches": { "$ref": "#/$defs/stringList" },
        "actions_focus_target_absent": { "$ref": "#/$defs/stringList" },
        "actions_write_after_hotkey_has_target": { "$ref": "#/$defs/stringList" },
        "done_when_matches": { "$ref": "#/$defs/stringList" },
        "done_when_absent": { "$ref": "#/$defs/stringList" },
        "step_text_matches": { "$ref": "#/$defs/stringList" },
        "step_text_matches_groups": { "$ref": "#/$defs/stringList" },
        "step_text_absent": { "$ref": "#/$defs/stringList" },
        "step_has_domain_needle": { "type": "boolean" },
        "goal_has_domain": { "type": "boolean" },
        "screen_contains_domain_needle": { "type": "boolean" },
        "screen_contains": { "$ref": "#/$defs/stringList" },
        "focused_title_matches": { "$ref": "#/$defs/stringList" },
        "focused_title_absent": { "$ref": "#/$defs/stringList" },
        "focused_contains_action_target": { "type": "boolean" },
        "focused_has_writable": { "type": "boolean" },
        "focused_element_role_any": { "$ref": "#/$defs/stringList" },
        "memory_has_key_from_action": { "type": "boolean" },
        "memory_stored_by_action": { "type": "boolean" },
        "memory_value_min_length": { "type": "integer", "minimum": 0 },
        "memory_value_below_length": { "type": "integer", "minimum": 0 },
        "memory_value_not_url": { "type": "boolean" },
        "memory_value_not_title": { "type": "boolean" },
        "memory_value_not_prior_write": { "type": "boolean" },
        "memory_value_not_question": { "type": "boolean" },
        "chain_is_launch": { "type": "boolean" },
        "chain_launch_then_content_write": { "type": "boolean" },
        "chain_launch_then_write_min_length": { "type": "integer", "minimum": 0 },
        "chain_is_navigation": { "type": "boolean" },
        "chain_is_save": { "type": "boolean" },
        "chain_wrote_and_submitted": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "actConfig": {
      "type": "object",
      "properties": {
        "valid_conclusions": { "$ref": "#/$defs/stringList" },
        "reject_conclusions": { "$ref": "#/$defs/stringList" },
        "verb_normalize": {
          "type": "array",
          "items": { "$ref": "#/$defs/verbNormalizer" }
        }
      },
      "additionalProperties": false
    },
    "verbNormalizer": {
      "type": "object",
      "required": ["from"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string" },
        "target_set": { "type": "string" },
        "value_set": { "type": "string" },
        "when_target_contains": { "type": "string" },
        "when_target_is": { "type": "string" },
        "when_target_empty": { "type": "boolean" },
        "when_target_nonempty": { "type": "boolean" },
        "when_value_empty": { "type": "boolean" },
        "when_target_equals_value": { "type": "boolean" },
        "when_focused_contains": { "$ref": "#/$defs/stringList" },
        "when_prior_verb": { "type": "string" },
        "when_prior_hotkey_contains": { "$ref": "#/$defs/stringList" }
      },
      "anyOf": [
        { "required": ["to"] },
        { "required": ["target_set"] },
        { "required": ["value_set"] }
      ],
      "additionalProperties": false
    },
    "prompt": {
      "type": "object",
      "properties": {
        "extends": { "type": "string" },
        "role": { "type": "string" },
        "user": {
          "type": "object",
          "properties": {
            "blocks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["label", "source"],
                "properties": {
                  "label": { "type": "string" },
                  "source": { "type": "string" },
                  "always": { "type": "boolean" },
                  "empty_template": { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    }
  }
}
