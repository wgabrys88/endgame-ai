{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "endgame-ai topology wiring",
  "type": "object",
  "required": ["schema", "topology", "prompts", "verbs"],
  "properties": {
    "schema": {"type": "string"},
    "instance": {"type": "object"},
    "moe": {"type": "object"},
    "topology": {
      "type": "object",
      "required": ["cycle_start", "nodes", "edges"],
      "properties": {
        "cycle_start": {"type": "string"},
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$"},
              "type": {"type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"},
              "label": {"type": "string"},
              "circuit": {"type": "string"},
              "prompt": {"type": "object"}
            },
            "additionalProperties": true
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "on"],
            "properties": {
              "from": {"type": "string"},
              "to": {"type": "string"},
              "on": {"type": "string", "minLength": 1}
            },
            "additionalProperties": true
          }
        },
        "layout": {
          "type": "object",
          "properties": {
            "positions": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {"x": {"type": "number"}, "y": {"type": "number"}},
                "required": ["x", "y"]
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "prompts": {
      "type": "object",
      "required": ["base", "roles"],
      "properties": {
        "base": {"type": "string"},
        "roles": {
          "type": "object",
          "required": ["planner", "unified", "verifier", "reflector", "self_modify"],
          "additionalProperties": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "verbs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "target_field": {"type": "string"},
          "value_field": {"type": "string"},
          "key_field": {"type": "string"},
          "title_field": {"type": "string"},
          "browser_field": {"type": "string"},
          "url_field": {"type": "string"},
          "amount_field": {"type": "string"},
          "description": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "act": {"type": "object"},
    "reasoning": {"type": "object"},
    "runtime": {"type": "object"},
    "errors": {"type": "object"},
    "limits": {"type": "object"},
    "observe": {"type": "object"},
    "rules": {"type": "array"}
  },
  "additionalProperties": true
}
