{
  "schema": "endgame-topology/v1",
  "instance": {
    "slot": 1,
    "permissions": [
      "desktop_exec"
    ]
  },
  "moe": {
    "required_permission": "desktop_exec",
    "delegate_keywords": [
      "chrome",
      "browser"
    ],
    "default_exec_slot": 1
  },
  "rules": [
    {
      "id": "deny_outcome_failed",
      "phase": "verify",
      "verdict": "deny",
      "description": "Any non-OK outcome is immediate denial",
      "match": {
        "outcome_failed": true
      }
    },
    {
      "id": "deny_chat_submission_missing_write",
      "phase": "verify",
      "verdict": "deny",
      "description": "chat submission preflight: no prompt text was written",
      "match": {
        "outcome_ok": true,
        "step_text_matches": [
          "send ",
          "message",
          "prompt",
          "follow-up",
          "question",
          "chat"
        ],
        "step_has_domain_needle": false,
        "step_text_absent": [
          "go to ",
          "navigate",
          "url",
          "website",
          "site",
          "page loads",
          "page is loaded"
        ],
        "actions_verb_absent": "write"
      }
    },
    {
      "id": "deny_chat_submission_navigation_text",
      "phase": "verify",
      "verdict": "deny",
      "description": "chat submission preflight: written text looks like navigation, not a chat prompt",
      "match": {
        "outcome_ok": true,
        "step_text_matches": [
          "send ",
          "message",
          "prompt",
          "follow-up",
          "question",
          "chat"
        ],
        "step_has_domain_needle": false,
        "step_text_absent": [
          "go to ",
          "navigate",
          "url",
          "website",
          "site",
          "page loads",
          "page is loaded"
        ],
        "actions_writes_all_url": true
      }
    },
    {
      "id": "deny_chat_submission_missing_submit",
      "phase": "verify",
      "verdict": "deny",
      "description": "chat submission preflight: prompt text was not submitted",
      "match": {
        "outcome_ok": true,
        "step_text_matches": [
          "send ",
          "message",
          "prompt",
          "follow-up",
          "question",
          "chat"
        ],
        "step_has_domain_needle": false,
        "step_text_absent": [
          "go to ",
          "navigate",
          "url",
          "website",
          "site",
          "page loads",
          "page is loaded"
        ],
        "actions_wrote_nonempty": true,
        "actions_writes_all_url": false,
        "actions_pressed_absent": "enter",
        "actions_click_target_line_absent": [
          "send",
          "submit"
        ]
      }
    },
    {
      "id": "deny_response_no_evidence",
      "phase": "verify",
      "verdict": "deny",
      "description": "response/reply/answer/content receipt requires observed evidence (remember, llm_wait_response, or interaction); waiting, scrolling, or passive verbs alone do not prove receipt",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "response|reply|answer|assistant|chatbot|streaming|content|message received|llm"
        ],
        "actions_verb_absent": "click",
        "actions_wrote_nonempty": false,
        "memory_stored_by_action": false,
        "memory_response_evidence": false
      }
    },
    {
      "id": "deny_wait_only_content_receipt",
      "phase": "verify",
      "verdict": "deny",
      "description": "wait-only actions cannot confirm steps whose done_when implies response/content receipt",
      "match": {
        "outcome_ok": true,
        "actions_all_verb": "wait",
        "done_when_matches": [
          "response",
          "reply",
          "answer",
          "assistant",
          "streaming",
          "content",
          "chatbot",
          "llm",
          "message received",
          "complete"
        ],
        "memory_response_evidence": false
      }
    },
    {
      "id": "deny_memory_capture_missing_value",
      "phase": "verify",
      "verdict": "deny",
      "description": "memory capture preflight: no response text was remembered",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "remember|capture|store",
          "response|reply|answer"
        ],
        "memory_stored_by_action": false
      }
    },
    {
      "id": "deny_memory_capture_prior_prompt",
      "phase": "verify",
      "verdict": "deny",
      "description": "memory capture preflight: remembered value matches a previously submitted prompt",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "remember|capture|store",
          "response|reply|answer"
        ],
        "memory_value_not_prior_write": false
      }
    },
    {
      "id": "deny_memory_capture_question",
      "phase": "verify",
      "verdict": "deny",
      "description": "memory capture preflight: remembered value looks like a question, not a response",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "remember|capture|store",
          "response|reply|answer"
        ],
        "memory_value_not_question": false
      }
    },
    {
      "id": "deny_memory_capture_title",
      "phase": "verify",
      "verdict": "deny",
      "description": "memory capture preflight: remembered value is only the focused window title",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "remember|capture|store",
          "response|reply|answer"
        ],
        "memory_value_not_title": false
      }
    },
    {
      "id": "deny_memory_capture_url",
      "phase": "verify",
      "verdict": "deny",
      "description": "memory capture preflight: remembered value is only a URL or domain",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "remember|capture|store",
          "response|reply|answer"
        ],
        "memory_value_not_url": false
      }
    },
    {
      "id": "deny_memory_capture_too_short",
      "phase": "verify",
      "verdict": "deny",
      "description": "memory capture preflight: remembered response is too short to be useful evidence",
      "match": {
        "outcome_ok": true,
        "step_text_matches_groups": [
          "remember|capture|store",
          "response|reply|answer"
        ],
        "memory_value_below_length": 30
      }
    },
    {
      "id": "confirm_launch_chain",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Win+R → type app → Enter is structurally proven launch",
      "match": {
        "outcome_ok": true,
        "chain_is_launch": true
      }
    },
    {
      "id": "confirm_browser_navigation",
      "phase": "verify",
      "verdict": "confirm",
      "description": "URL typed into address bar + Enter + domain visible",
      "match": {
        "outcome_ok": true,
        "chain_is_navigation": true,
        "actions_hotkey_contains": [
          "ctrl",
          "l"
        ],
        "done_when_absent": [
          "playing",
          "playback"
        ],
        "screen_contains_domain_needle": true
      }
    },
    {
      "id": "confirm_browser_navigation_address_target",
      "phase": "verify",
      "verdict": "confirm",
      "description": "URL typed into address field + Enter + domain visible",
      "match": {
        "outcome_ok": true,
        "chain_is_navigation": true,
        "actions_write_target_line_contains": [
          "address"
        ],
        "done_when_absent": [
          "playing",
          "playback"
        ],
        "screen_contains_domain_needle": true
      }
    },
    {
      "id": "confirm_remember_action",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Remember verb has no side effect; OK = data captured",
      "match": {
        "outcome_ok": true,
        "actions_all_verb": "remember"
      }
    },
    {
      "id": "confirm_llm_request_written",
      "phase": "verify",
      "verdict": "confirm",
      "description": "llm_request wrote the external-AI handoff file",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "llm_request"
      }
    },
    {
      "id": "confirm_llm_response_received",
      "phase": "verify",
      "verdict": "confirm",
      "description": "llm_wait_response loaded external AI answer into MEMORY.llm_response",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "llm_wait_response",
        "memory_has_key": "llm_response",
        "memory_key_min_length": 20
      }
    },
    {
      "id": "confirm_browser_open_url",
      "phase": "verify",
      "verdict": "confirm",
      "description": "open_url launched browser to target domain",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "open_url",
        "done_when_absent": [
          "playing",
          "playback"
        ],
        "outcome_contains_domain_needle": true
      }
    },
    {
      "id": "confirm_youtube_playback",
      "phase": "verify",
      "verdict": "confirm",
      "description": "YouTube video page reached with playback evidence in title or screen",
      "match": {
        "outcome_ok": true,
        "done_when_matches": [
          "playing",
          "playback",
          "video",
          "waka",
          "shakira"
        ],
        "screen_contains": [
          "youtube.com/watch",
          "pause",
          "playing"
        ],
        "focused_title_matches": [
          "youtube",
          "waka",
          "shakira"
        ]
      }
    },
    {
      "id": "deny_youtube_blocker",
      "phase": "verify",
      "verdict": "deny",
      "description": "YouTube playback blocked by login wall, cookie banner, or ad gate",
      "match": {
        "outcome_ok": true,
        "done_when_matches": [
          "playing",
          "playback",
          "video"
        ],
        "screen_contains": [
          "sign in to confirm",
          "accept all",
          "before you continue to youtube",
          "skip ad",
          "ad ·"
        ]
      }
    },
    {
      "id": "confirm_write_to_writable",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Write to focused writable field with text proven typed",
      "match": {
        "outcome_ok": true,
        "done_when_matches": [
          "written",
          "write",
          "typed",
          "text",
          "entered",
          "pasted",
          "summary"
        ],
        "actions_include_verb": "write",
        "actions_wrote_nonempty": true,
        "focused_element_role_any": [
          "edit",
          "document",
          "combobox",
          "input",
          "textarea"
        ]
      }
    },
    {
      "id": "confirm_save_hotkey",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Ctrl+S with done_when mentioning save",
      "match": {
        "outcome_ok": true,
        "chain_is_save": true,
        "done_when_matches": [
          "save",
          "saved"
        ]
      }
    },
    {
      "id": "confirm_focus_matches_done_when",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Focus verb succeeded and target words appear in done_when",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "focus",
        "focused_contains_action_target": true,
        "done_when_matches": [
          "open",
          "focused",
          "active",
          "front",
          "visible"
        ]
      }
    },
    {
      "id": "reject_chat_write_to_address_bar",
      "phase": "act",
      "verdict": "reject",
      "description": "chat/message write targeted the browser address bar; observe or navigate until a chat input is visible",
      "match": {
        "step_text_matches": [
          "send ",
          "message",
          "prompt",
          "follow-up",
          "question",
          "chat"
        ],
        "step_has_domain_needle": false,
        "step_text_absent": [
          "go to ",
          "navigate",
          "url",
          "website",
          "site",
          "page loads",
          "page is loaded"
        ],
        "actions_write_target_line_contains": [
          "address and search bar",
          "address bar"
        ]
      }
    },
    {
      "id": "reject_navigation_write_without_ctrl_l",
      "phase": "act",
      "verdict": "reject",
      "description": "navigation write requires ctrl+l before URL/query text; retry with ctrl+l, write, then enter",
      "match": {
        "step_has_domain_needle": true,
        "actions_wrote_nonempty": true,
        "actions_hotkey_absent": [
          "ctrl",
          "l"
        ],
        "actions_write_target_line_absent": [
          "address"
        ],
        "actions_verb_absent": "focus"
      }
    },
    {
      "id": "reject_navigation_without_browser_context",
      "phase": "act",
      "verdict": "reject",
      "description": "browser navigation/search requires a browser or address bar focused; focus/open browser first",
      "match": {
        "step_has_domain_needle": true,
        "actions_wrote_nonempty": true,
        "actions_hotkey_absent": [
          "ctrl",
          "l"
        ],
        "actions_write_target_line_absent": [
          "address"
        ],
        "actions_verb_absent": "open_url",
        "focused_title_absent": [
          "chrome",
          "edge",
          "firefox",
          "opera",
          "browser"
        ],
        "actions_focus_target_absent": [
          "chrome",
          "edge",
          "firefox",
          "opera",
          "browser"
        ]
      }
    },
    {
      "id": "reject_response_capture_during_stream",
      "phase": "act",
      "verdict": "reject",
      "description": "do not remember while the provider still shows streaming/loading controls",
      "match": {
        "step_text_matches_groups": [
          "remember|capture|store|extract",
          "assistant|response|answer"
        ],
        "actions_include_verb": "remember",
        "screen_contains": [
          "stop generating",
          "generating",
          "thinking",
          "streaming",
          "loading",
          "cancel response",
          "continue generating"
        ]
      }
    },
    {
      "id": "reject_navigation_missing_enter",
      "phase": "act",
      "verdict": "reject",
      "description": "navigation write must submit with Enter; retry with ctrl+l, write, then press enter",
      "match": {
        "step_has_domain_needle": true,
        "actions_wrote_nonempty": true,
        "actions_pressed_absent": "enter"
      }
    },
    {
      "id": "reject_navigation_target_after_ctrl_l",
      "phase": "act",
      "verdict": "reject",
      "description": "after ctrl+l, write URL/query text to the focused address field with an empty target",
      "match": {
        "step_has_domain_needle": true,
        "actions_write_after_hotkey_has_target": [
          "ctrl",
          "l"
        ]
      }
    },
    {
      "id": "reject_launch_then_long_content_write",
      "phase": "act",
      "verdict": "reject",
      "description": "do not chain content writing immediately after launching an app; observe/focus the editor first",
      "match": {
        "chain_launch_then_write_min_length": 21
      }
    },
    {
      "id": "reject_launch_then_summary_write",
      "phase": "act",
      "verdict": "reject",
      "description": "do not chain content writing immediately after launching an app; observe/focus the editor first",
      "match": {
        "step_text_matches": [
          "summary"
        ],
        "chain_launch_then_content_write": true
      }
    }
  ],
  "topology": {
    "cycle_start": "goal_inbox",
    "nodes": [
      {
        "id": "goal_inbox",
        "type": "entry",
        "label": "Goal input"
      },
      {
        "id": "moe_route",
        "type": "moe_route",
        "label": "Route goal to slot"
      },
      {
        "id": "planner",
        "type": "planner",
        "label": "Decompose goal → steps",
        "circuit": "planner",
        "prompt": {
          "extends": "base",
          "role": "planner",
          "user": {
            "blocks": [
              {
                "label": "GOAL",
                "source": "state.goal",
                "always": true
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "COMPLETED_STEPS",
                "source": "state.step"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              },
              {
                "label": "PRIOR_TRACES",
                "source": "traces.recent"
              }
            ]
          }
        }
      },
      {
        "id": "scheduler",
        "type": "scheduler",
        "label": "Next step or done"
      },
      {
        "id": "bus_check",
        "type": "bus_check",
        "label": "Poll bus for interrupts"
      },
      {
        "id": "observe",
        "type": "observe",
        "label": "Screen capture"
      },
      {
        "id": "act",
        "type": "act",
        "label": "LLM decide + guards + execute",
        "circuit": "unified",
        "prompt": {
          "extends": "base",
          "role": "unified",
          "user": {
            "blocks": [
              {
                "label": "SUBTASK",
                "source": "state.step_goal",
                "always": true
              },
              {
                "label": "DONE_WHEN",
                "source": "state.current_step.done_when"
              },
              {
                "label": "SCREEN",
                "source": "state.screen",
                "empty_template": "(no screen)"
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              }
            ]
          }
        }
      },
      {
        "id": "verify",
        "type": "verify",
        "label": "Check step evidence",
        "circuit": "verifier",
        "prompt": {
          "extends": "base",
          "role": "verifier",
          "user": {
            "blocks": [
              {
                "label": "STEP",
                "source": "state.current_step.description",
                "always": true
              },
              {
                "label": "DONE_WHEN",
                "source": "state.current_step.done_when"
              },
              {
                "label": "LAST_ACTIONS",
                "source": "state.last_actions"
              },
              {
                "label": "LAST_ACTIONS_RAW",
                "source": "state.last_actions_raw"
              },
              {
                "label": "LAST_OUTCOME",
                "source": "state.last_outcome"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              }
            ]
          }
        }
      },
      {
        "id": "reflect",
        "type": "reflect",
        "label": "Diagnose + retry/replan",
        "circuit": "reflector",
        "prompt": {
          "extends": "base",
          "role": "reflector",
          "user": {
            "blocks": [
              {
                "label": "GOAL",
                "source": "state.goal",
                "always": true
              },
              {
                "label": "STEP",
                "source": "state.current_step.description",
                "always": true
              },
              {
                "label": "DONE_WHEN",
                "source": "state.current_step.done_when"
              },
              {
                "label": "LAST_ACTIONS",
                "source": "state.last_actions"
              },
              {
                "label": "LAST_ACTIONS_RAW",
                "source": "state.last_actions_raw"
              },
              {
                "label": "LAST_OUTCOME",
                "source": "state.last_outcome"
              },
              {
                "label": "VERIFY_REASONING",
                "source": "reasoning.verify"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              }
            ]
          }
        }
      },
      {
        "id": "self_modify",
        "type": "self_modify",
        "label": "Alter own wiring",
        "circuit": "self_modify",
        "prompt": {
          "extends": "base",
          "role": "self_modify",
          "user": {
            "blocks": [
              {
                "label": "GOAL",
                "source": "state.goal",
                "always": true
              },
              {
                "label": "REASONING_CHAIN",
                "source": "reasoning.chain"
              },
              {
                "label": "REFLECT_REASONING",
                "source": "reasoning.reflect"
              },
              {
                "label": "VERIFY_REASONING",
                "source": "reasoning.verify"
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              },
              {
                "label": "CURRENT_NODES",
                "source": "topology.nodes"
              },
              {
                "label": "CURRENT_WIRING",
                "source": "topology.summary"
              }
            ]
          }
        }
      },
      {
        "id": "satisfied",
        "type": "satisfied",
        "label": "Rest"
      },
      {
        "id": "bus_post",
        "type": "bus_post",
        "label": "Post telemetry"
      }
    ],
    "edges": [
      {
        "from": "goal_inbox",
        "to": "moe_route",
        "on": "ready"
      },
      {
        "from": "moe_route",
        "to": "planner",
        "on": "self"
      },
      {
        "from": "moe_route",
        "to": "bus_post",
        "on": "delegated"
      },
      {
        "from": "planner",
        "to": "scheduler",
        "on": "plan_ready"
      },
      {
        "from": "planner",
        "to": "planner",
        "on": "retry_plan"
      },
      {
        "from": "planner",
        "to": "bus_post",
        "on": "plan_failed"
      },
      {
        "from": "scheduler",
        "to": "bus_check",
        "on": "step_ready"
      },
      {
        "from": "scheduler",
        "to": "bus_post",
        "on": "plan_complete"
      },
      {
        "from": "bus_post",
        "to": "satisfied",
        "on": "posted"
      },
      {
        "from": "bus_check",
        "to": "observe",
        "on": "no_interrupt"
      },
      {
        "from": "bus_check",
        "to": "planner",
        "on": "interrupt"
      },
      {
        "from": "observe",
        "to": "act",
        "on": "screen_ready"
      },
      {
        "from": "act",
        "to": "verify",
        "on": "acted"
      },
      {
        "from": "act",
        "to": "reflect",
        "on": "act_failed"
      },
      {
        "from": "verify",
        "to": "scheduler",
        "on": "step_confirmed"
      },
      {
        "from": "verify",
        "to": "reflect",
        "on": "step_denied"
      },
      {
        "from": "reflect",
        "to": "scheduler",
        "on": "retry"
      },
      {
        "from": "reflect",
        "to": "planner",
        "on": "replan"
      },
      {
        "from": "reflect",
        "to": "self_modify",
        "on": "escalate"
      },
      {
        "from": "reflect",
        "to": "bus_post",
        "on": "give_up"
      },
      {
        "from": "self_modify",
