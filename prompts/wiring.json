{
  "schema": "endgame-topology/v1",
  "instance": {
    "slot": 1,
    "permissions": [
      "desktop_exec"
    ]
  },
  "moe": {
    "required_permission": "desktop_exec",
    "delegate_keywords": [
      "chrome",
      "browser"
    ],
    "default_exec_slot": 1
  },
  "rules": [
    {
      "id": "confirm_launch_chain",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Win+R \u2192 type app \u2192 Enter is structurally proven launch",
      "match": {
        "outcome_ok": true,
        "chain_is_launch": true
      }
    },
    {
      "id": "confirm_browser_navigation",
      "phase": "verify",
      "verdict": "confirm",
      "description": "URL typed into address bar + Enter + domain visible",
      "match": {
        "outcome_ok": true,
        "chain_is_navigation": true,
        "actions_hotkey_contains": [
          "ctrl",
          "l"
        ],
        "done_when_absent": [
          "playing",
          "playback"
        ],
        "screen_contains_domain_needle": true
      }
    },
    {
      "id": "confirm_browser_navigation_address_target",
      "phase": "verify",
      "verdict": "confirm",
      "description": "URL typed into address field + Enter + domain visible",
      "match": {
        "outcome_ok": true,
        "chain_is_navigation": true,
        "actions_write_target_line_contains": [
          "address"
        ],
        "done_when_absent": [
          "playing",
          "playback"
        ],
        "screen_contains_domain_needle": true
      }
    },
    {
      "id": "confirm_remember_action",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Remember verb has no side effect; OK = data captured",
      "match": {
        "outcome_ok": true,
        "actions_all_verb": "remember"
      }
    },
    {
      "id": "confirm_llm_request_written",
      "phase": "verify",
      "verdict": "confirm",
      "description": "llm_request wrote the external-AI handoff file",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "llm_request"
      }
    },
    {
      "id": "confirm_llm_response_received",
      "phase": "verify",
      "verdict": "confirm",
      "description": "llm_wait_response loaded external AI answer into MEMORY.llm_response",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "llm_wait_response",
        "memory_has_key": "llm_response",
        "memory_key_min_length": 20
      }
    },
    {
      "id": "confirm_browser_open_url",
      "phase": "verify",
      "verdict": "confirm",
      "description": "open_url launched browser to target domain",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "open_url",
        "done_when_absent": [
          "playing",
          "playback"
        ],
        "outcome_contains_domain_needle": true
      }
    },
    {
      "id": "confirm_youtube_playback",
      "phase": "verify",
      "verdict": "confirm",
      "description": "YouTube video page reached with playback evidence in title or screen",
      "match": {
        "outcome_ok": true,
        "done_when_matches": [
          "playing",
          "playback",
          "video",
          "waka",
          "shakira"
        ],
        "screen_contains": [
          "youtube.com/watch",
          "pause",
          "playing"
        ],
        "focused_title_matches": [
          "youtube",
          "waka",
          "shakira"
        ]
      }
    },
    {
      "id": "confirm_write_to_writable",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Write to focused writable field with text proven typed",
      "match": {
        "outcome_ok": true,
        "done_when_matches": [
          "written",
          "write",
          "typed",
          "text",
          "entered",
          "pasted",
          "summary"
        ],
        "actions_include_verb": "write",
        "actions_wrote_nonempty": true,
        "focused_element_role_any": [
          "edit",
          "document",
          "combobox",
          "input",
          "textarea"
        ]
      }
    },
    {
      "id": "confirm_save_hotkey",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Ctrl+S with done_when mentioning save",
      "match": {
        "outcome_ok": true,
        "chain_is_save": true,
        "done_when_matches": [
          "save",
          "saved"
        ]
      }
    },
    {
      "id": "confirm_focus_matches_done_when",
      "phase": "verify",
      "verdict": "confirm",
      "description": "Focus verb succeeded and target words appear in done_when",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "focus",
        "focused_contains_action_target": true,
        "done_when_matches": [
          "open",
          "focused",
          "active",
          "front",
          "visible"
        ]
      }
    },
    {
      "id": "confirm_launch_verb",
      "phase": "verify",
      "verdict": "confirm",
      "description": "launch verb succeeded and post-action title matches app",
      "match": {
        "outcome_ok": true,
        "actions_include_verb": "launch"
      }
    }
  ],
  "topology": {
    "cycle_start": "goal_inbox",
    "nodes": [
      {
        "id": "goal_inbox",
        "type": "entry",
        "label": "Goal input"
      },
      {
        "id": "moe_route",
        "type": "moe_route",
        "label": "Route goal to slot"
      },
      {
        "id": "planner",
        "type": "planner",
        "label": "Decompose goal \u2192 steps",
        "circuit": "planner",
        "prompt": {
          "extends": "base",
          "role": "planner",
          "user": {
            "blocks": [
              {
                "label": "GOAL",
                "source": "state.goal",
                "always": true
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "COMPLETED_STEPS",
                "source": "state.step"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              },
              {
                "label": "PRIOR_TRACES",
                "source": "traces.recent"
              }
            ]
          }
        }
      },
      {
        "id": "scheduler",
        "type": "scheduler",
        "label": "Next step or done"
      },
      {
        "id": "bus_check",
        "type": "bus_check",
        "label": "Poll bus for interrupts"
      },
      {
        "id": "observe",
        "type": "observe",
        "label": "Screen capture"
      },
      {
        "id": "act",
        "type": "act",
        "label": "LLM decide + guards + execute",
        "circuit": "unified",
        "prompt": {
          "extends": "base",
          "role": "unified",
          "user": {
            "blocks": [
              {
                "label": "SUBTASK",
                "source": "state.step_goal",
                "always": true
              },
              {
                "label": "DONE_WHEN",
                "source": "state.current_step.done_when"
              },
              {
                "label": "SCREEN",
                "source": "state.screen",
                "empty_template": "(no screen)"
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              }
            ]
          }
        }
      },
      {
        "id": "verify",
        "type": "verify",
        "label": "Check step evidence",
        "circuit": "verifier",
        "prompt": {
          "extends": "base",
          "role": "verifier",
          "user": {
            "blocks": [
              {
                "label": "STEP",
                "source": "state.current_step.description",
                "always": true
              },
              {
                "label": "DONE_WHEN",
                "source": "state.current_step.done_when"
              },
              {
                "label": "LAST_ACTIONS",
                "source": "state.last_actions"
              },
              {
                "label": "LAST_ACTIONS_RAW",
                "source": "state.last_actions_raw"
              },
              {
                "label": "LAST_OUTCOME",
                "source": "state.last_outcome"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              }
            ]
          }
        }
      },
      {
        "id": "reflect",
        "type": "reflect",
        "label": "Diagnose + retry/replan",
        "circuit": "reflector",
        "prompt": {
          "extends": "base",
          "role": "reflector",
          "user": {
            "blocks": [
              {
                "label": "GOAL",
                "source": "state.goal",
                "always": true
              },
              {
                "label": "STEP",
                "source": "state.current_step.description",
                "always": true
              },
              {
                "label": "DONE_WHEN",
                "source": "state.current_step.done_when"
              },
              {
                "label": "LAST_ACTIONS",
                "source": "state.last_actions"
              },
              {
                "label": "LAST_ACTIONS_RAW",
                "source": "state.last_actions_raw"
              },
              {
                "label": "LAST_OUTCOME",
                "source": "state.last_outcome"
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "VERIFY_REASONING",
                "source": "reasoning.verify"
              },
              {
                "label": "MEMORY",
                "source": "state.memory"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              }
            ]
          }
        }
      },
      {
        "id": "self_modify",
        "type": "self_modify",
        "label": "Alter own wiring",
        "circuit": "self_modify",
        "prompt": {
          "extends": "base",
          "role": "self_modify",
          "user": {
            "blocks": [
              {
                "label": "GOAL",
                "source": "state.goal",
                "always": true
              },
              {
                "label": "REASONING_CHAIN",
                "source": "reasoning.chain"
              },
              {
                "label": "REFLECT_REASONING",
                "source": "reasoning.reflect"
              },
              {
                "label": "VERIFY_REASONING",
                "source": "reasoning.verify"
              },
              {
                "label": "LAST_ERROR",
                "source": "state.last_error"
              },
              {
                "label": "HISTORY",
                "source": "state.history"
              },
              {
                "label": "CURRENT_NODES",
                "source": "topology.nodes"
              },
              {
                "label": "CURRENT_WIRING",
                "source": "topology.summary"
              }
            ]
          }
        }
      },
      {
        "id": "satisfied",
        "type": "satisfied",
        "label": "Rest"
      },
      {
        "id": "bus_post",
        "type": "bus_post",
        "label": "Post telemetry"
      }
    ],
    "edges": [
      {
        "from": "goal_inbox",
        "to": "moe_route",
        "on": "ready"
      },
      {
        "from": "moe_route",
        "to": "planner",
        "on": "self"
      },
      {
        "from": "moe_route",
        "to": "bus_post",
        "on": "delegated"
      },
      {
        "from": "planner",
        "to": "scheduler",
        "on": "plan_ready"
      },
      {
        "from": "planner",
        "to": "planner",
        "on": "retry_plan"
      },
      {
        "from": "planner",
        "to": "bus_post",
        "on": "plan_failed"
      },
      {
        "from": "scheduler",
        "to": "bus_check",
        "on": "step_ready"
      },
      {
        "from": "scheduler",
        "to": "bus_post",
        "on": "plan_complete"
      },
      {
        "from": "bus_post",
        "to": "satisfied",
        "on": "posted"
      },
      {
        "from": "bus_check",
        "to": "observe",
        "on": "no_interrupt"
      },
      {
        "from": "bus_check",
        "to": "planner",
        "on": "interrupt"
      },
      {
        "from": "observe",
        "to": "act",
        "on": "screen_ready"
      },
      {
        "from": "act",
        "to": "verify",
        "on": "acted"
      },
      {
        "from": "act",
        "to": "reflect",
        "on": "act_failed"
      },
      {
        "from": "verify",
        "to": "scheduler",
        "on": "step_confirmed"
      },
      {
        "from": "verify",
        "to": "reflect",
        "on": "step_denied"
      },
      {
        "from": "reflect",
        "to": "scheduler",
        "on": "retry"
      },
      {
        "from": "reflect",
        "to": "planner",
        "on": "replan"
      },
      {
        "from": "reflect",
        "to": "self_modify",
        "on": "escalate"
      },
      {
        "from": "reflect",
        "to": "bus_post",
        "on": "give_up"
      },
      {
        "from": "self_modify",
        "to": "planner",
        "on": "modified"
      },
      {
        "from": "self_modify",
        "to": "reflect",
        "on": "modify_failed"
      }
    ]
  },
  "reasoning": {
    "store_as": {
      "planner": "planner",
      "unified": "act",
      "verifier": "verify",
      "reflector": "reflect",
      "self_modify": "self_modify"
    },
    "expected_record_type": {
      "planner": "task",
      "unified": "action",
      "verifier": "verdict",
      "reflector": "diagnosis",
      "self_modify": "wiring_patch"
    },
    "chain_depth": 32,
    "clear_on_step_confirm": [
      "verify",
      "reflect",
      "act"
    ]
  },
  "prompts": {
    "base": "You are one circuit in Endgame-AI \u2014 a serious computer operator. Python owns the mouse; YOU decide what to do next.\n\nTwo-pass contract:\n- Without DECIDE NOW: reason briefly about INPUT (prose allowed).\n- With DECIDE NOW: content = exactly ONE JSON object for your ROLE. No prose.\n\nOperator vs runtime (important):\n- YOU (planner/act/verifier/reflector) are the operator brain.\n- wiring.json rules are NOT sent to you. Python may auto-confirm/deny verify from structural evidence before the Verifier circuit runs.\n- LAST_ERROR and HISTORY entries like verify:rule_id are runtime feedback \u2014 adapt your next decision; do not treat them as a rulebook to obey.\n\nFacts:\n- Only Act sees SCREEN. [ID] = click/write targets. [W#] = focus tokens.\n- Never invent [ID] from WINDOWS or DESKTOP_TREE.\n- Goal literals beat history. No evidence \u2192 CANNOT or confirmed:false \u2014 never guess.",
    "roles": {
      "planner": "ROLE: Planner. Split GOAL into 1-8 short steps. No SCREEN. You are the strategic operator.\n\nDECIDE NOW output:\n{\"record_type\":\"task\",\"data\":{\"steps\":[{\"description\":\"...\",\"done_when\":\"...\"}]}}\n\nGuidance:\n- done_when = plain observable English (no [ID] or coordinates).\n- Keep exact literals from goal: URLs, app names, text to type.\n- Skip work already in MEMORY or COMPLETED_STEPS.\n- New site: navigate/open step first unless already open per MEMORY/history.\n- Smarter AI: (A) browser chat steps (grok.com, etc.) submit+capture; OR (B) llm_request then llm_wait_response; then use MEMORY.llm_response.\n- YouTube/media: search then play/open result.\n- Never output actions, verdicts, or wiring patches.",
      "unified": "ROLE: Act. You alone see SCREEN. You are the hands operator \u2014 decide verbs from evidence.\n\nDECIDE NOW output:\n{\"record_type\":\"action\",\"data\":{\"conclusion\":\"EXECUTE|CANNOT\",\"actions\":[{\"verb\":\"...\",\"target\":\"...\",\"value\":\"...\"}]}}\n\nVerbs: click, write, press, hotkey, focus, open_url, scroll, wait, launch, remember, llm_request, llm_wait_response\n\nGuidance:\n- LAST_ERROR = runtime feedback (including structural verify blocks), not a script. Read SCREEN and adapt.\n- click/write/scroll \u2192 [ID] from SCREEN. focus \u2192 [W#] or title. open_url \u2192 chrome|edge + URL.\n- remember \u2192 SCREEN fact to MEMORY. llm_request/llm_wait_response when step requires external AI answer.\n- Launch: use launch verb with app name (e.g. launch target=app value=notepad). Equivalent to win+r \u2192 write app \u2192 enter. Chat: write composer [ID] \u2192 enter/send.\n- 1-4 actions per turn. EXECUTE needs \u22651 action. No DONE.",
      "verifier": "ROLE: Verifier. You run only when runtime structural checks did not already decide. Judge DONE_WHEN from evidence.\n\nDECIDE NOW output:\n{\"record_type\":\"verdict\",\"data\":{\"confirmed\":true|false,\"evidence\":\"...\",\"reason\":\"...\"}}\n\nGuidance:\n- You are the operator's judgment circuit \u2014 not a rule executor. wiring.json rules are Python's fast path; you are the fallback.\n- confirmed=true only if LAST_OUTCOME/actions satisfy DONE_WHEN or MEMORY has the fact.\n- win+r alone \u2260 app opened. FAILED/BLOCKED/CANNOT \u2192 confirmed=false.\n- Cite LAST_OUTCOME, LAST_ACTIONS, MEMORY only.",
      "reflector": "ROLE: Reflector. Diagnose why the step was denied. No SCREEN.\n\nDECIDE NOW output:\n{\"record_type\":\"diagnosis\",\"data\":{\"diagnosis\":\"...\",\"suggestion\":\"...\",\"should_replan\":false}}\n\nGuidance:\n- LAST_ERROR often means runtime blocked premature success (HISTORY may show verify:rule_id). Tell act/planner what to do differently \u2014 do not recite rules.\n- One cause: stale SCREEN, wrong focus, missing MEMORY, bad subtask, site loading.\n- suggestion = strategy (no coordinates). should_replan=true if subtask or capture step is wrong.\n- Video: click result, don't repeat search. Stuck loops \u2192 suggest escalation.",
      "self_modify": "ROLE: Self_modify. One minimal wiring.json patch when policy blocks progress.\n\nDECIDE NOW output:\n{\"record_type\":\"wiring_patch\",\"data\":{\"op\":\"...\",\"payload\":{...}}}\n\nOps: add_rule, update_rule, remove_rule, set_observe, set_limit, set_guard, set_role, append_role_rule, add_edge, remove_edge, add_node, update_node, remove_node, set_prompt_base, set_reasoning.\n\nPolicy:\n- set_observe if SCREEN shallow; add_rule if repeated verify pattern; append_role_rule if model repeats mistakes.\n- verify rules: confirm|deny. act rules: reject. Copy match keys from CURRENT_WIRING existing rules.\n- Keep observe\u2192act\u2192verify\u2192scheduler routes.\n- One patch only. No prose."
    }
  },
  "guards": {},
  "runtime": {
    "http_port_base": 9077,
    "http_port_slot_offset": true,
    "http_bind": "0.0.0.0",
    "cycle_delay_ms": 300,
    "action_chain_delay_ms": 120,
    "llm_request_path": "comms/llm_proxy/request.json",
    "llm_response_path": "comms/llm_proxy/response.json",
    "llm_archive_dir": "comms/llm_proxy/archive",
    "llm_wait_timeout_ms": 60000,
    "llm_response_memory_key": "llm_response",
    "llm_response_min_chars": 20,
    "initial_state": {
      "step": 0,
      "retries": 0,
      "no_desktop": false,
      "history": [],
      "memory": {},
      "reasoning": {},
      "reasoning_chain": [],
      "planner_retries": 0,
      "replan_count": 0,
      "last_error": ""
    }
  },
  "act": {
    "valid_conclusions": [
      "EXECUTE",
      "CANNOT"
    ],
    "reject_conclusions": [
      "DONE"
    ],
    "verb_normalize": [
      {
        "from": "press",
        "to": "hotkey",
        "when_target_contains": "+"
      },
      {
        "from": "write",
        "when_target_nonempty": true,
        "target_set": "",
        "when_focused_exact": [
          "run"
        ]
      },
      {
        "from": "write",
        "when_prior_hotkey_contains": [
          "win",
          "r"
        ],
        "when_target_equals_value": true,
        "target_set": ""
      },
      {
        "from": "press",
        "when_target_empty": true,
        "when_value_empty": true,
        "when_prior_verb": "write",
        "target_set": "enter"
      },
      {
        "from": "click",
        "to": "press",
        "when_target_is": "ok",
        "target_set": "enter",
        "value_set": "",
        "when_focused_exact": [
          "run"
        ]
      }
    ]
  },
  "errors": {
    "parse_failed": "parse_failed: respond with JSON only",
    "act_done_rejected": "DONE is invalid \u2014 output EXECUTE with one action; verify node confirms step completion",
    "act_cannot": "CANNOT",
    "act_bad_conclusion": "bad conclusion: {conclusion}",
    "verify_parse_failed": "verify parse failed",
    "verify_preflight_denied": "verify preflight: LAST_OUTCOME not OK",
    "reflector_parse_failed": "reflector: parse_failed or wrong record_type \u2014 output diagnosis JSON only",
    "planner_parse_failed": "planner: parse_failed \u2014 respond with JSON only",
    "planner_empty": "planner: empty plan",
    "self_modify_invalid": "LLM returned invalid patch"
  },
  "limits": {
    "max_attempts": 7,
    "max_replans": 3,
    "max_self_modify": 3,
    "max_cycles": 300,
    "history_depth": 40,
    "reasoning_chain_depth": 32,
    "bus_max": 400,
    "planner_retries": 3,
    "llm_parse_retries": 2,
    "trace_few_shot": 6,
    "debug_value_max_chars": 12000,
    "error_preview_chars": 8000,
    "context_window_tokens": 17920,
    "context_reserve_tokens": 2560
  },
  "verbs": {
    "click": {
      "target_field": "target"
    },
    "write": {
      "target_field": "target",
      "value_field": "value"
    },
    "press": {
      "key_field": "target"
    },
    "hotkey": {
      "key_field": "target"
    },
    "scroll": {
      "target_field": "target",
      "amount_field": "value"
    },
    "focus": {
      "title_field": "target"
    },
    "open_url": {
      "browser_field": "target",
      "url_field": "value"
    },
    "remember": {
      "target_field": "target",
      "value_field": "value"
    },
    "llm_request": {
      "target_field": "target",
      "value_field": "value"
    },
    "llm_wait_response": {
      "target_field": "target",
      "value_field": "value"
    },
    "wait": {
      "amount_field": "value"
    },
    "launch": {
      "target_field": "target",
      "value_field": "value"
    }
  },
  "context": {
    "screen_disabled": "(desktop observation disabled)"
  },
  "observe": {
    "min_elements": 3,
    "wait_retries": 6,
    "wait_ms": 750,
    "probe_step_px": 40,
    "probe_delay_ms": 1,
    "hover_scan_enabled": true,
    "hover_scan_step_px": 70,
    "hover_scan_delay_ms": 1,
    "dense_probe_min_px": 24,
    "scroll_enrich_min": 3,
    "scroll_enrich_passes": [
      -3,
      -2,
      2,
      3
    ],
    "scroll_enrich_delay_ms": 80,
    "read_text_max": 16000,
    "scope_depth": 4,
    "element_text_max": 500,
    "render_focused_first": true,
