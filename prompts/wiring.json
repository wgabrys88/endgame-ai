{
  "schema": "endgame-topology/v1",
  "instance": {
    "role": "implementor",
    "persona": "implementor",
    "slot": 1,
    "permissions": ["desktop_exec", "bus_post"]
  },
  "topology": {
    "cycle_start": "goal_inbox",
    "nodes": [
      {"id": "goal_inbox", "type": "entry", "label": "Goal input"},
      {"id": "planner", "type": "planner", "label": "Decompose goal → steps"},
      {"id": "scheduler", "type": "scheduler", "label": "Next step or done"},
      {"id": "observe", "type": "observe", "label": "Screen capture"},
      {"id": "act", "type": "act", "label": "LLM decide + execute"},
      {"id": "verify", "type": "verify", "label": "Check step evidence"},
      {"id": "reflect", "type": "reflect", "label": "Diagnose + retry/replan"},
      {"id": "satisfied", "type": "satisfied", "label": "Rest"}
    ],
    "edges": [
      {"from": "goal_inbox", "to": "planner", "on": "ready"},
      {"from": "planner", "to": "scheduler", "on": "plan_ready"},
      {"from": "scheduler", "to": "observe", "on": "step_ready"},
      {"from": "scheduler", "to": "satisfied", "on": "plan_complete"},
      {"from": "observe", "to": "act", "on": "screen_ready"},
      {"from": "act", "to": "verify", "on": "acted|step_done"},
      {"from": "act", "to": "reflect", "on": "act_failed"},
      {"from": "verify", "to": "scheduler", "on": "step_confirmed"},
      {"from": "verify", "to": "reflect", "on": "step_denied"},
      {"from": "reflect", "to": "scheduler", "on": "retry"},
      {"from": "reflect", "to": "planner", "on": "replan"}
    ]
  },
  "request": {
    "unified": {
      "system": {"file": "unified.txt"},
      "user": {
        "blocks": [
          {"label": "GOAL", "source": "state.step_goal", "always": true},
          {"label": "SCREEN", "source": "state.screen", "empty_template": "(no screen)"},
          {"label": "LAST ERROR", "source": "state.last_error"}
        ]
      }
    }
  },
  "circuits": {
    "unified": {
      "prompt": "unified.txt",
      "prompt_swap": [
        {"when": ["MANAGER.md", "student instance", "orchestrate the student"], "prompt": "manager.txt"}
      ]
    }
  },
  "limits": {
    "max_attempts": 5,
    "bus_max": 200
  },
  "verbs": {
    "click": {"target_field": "target"},
    "write": {"target_field": "target", "value_field": "value"},
    "press": {"key_field": "target"},
    "hotkey": {"key_field": "target"},
    "scroll": {"target_field": "target", "amount_field": "value"},
    "focus": {"title_field": "target"}
  },
  "context": {
    "screen_disabled": "(desktop observation disabled)"
  }
}
