  "reasoning": {
    "store_as": {
      "planner": "planner",
      "unified": "act",
      "verifier": "verify",
      "reflector": "reflect",
      "self_modify": "self_modify"
    },
    "expected_record_type": {
      "planner": "task",
      "unified": "action",
      "verifier": "verdict",
      "reflector": "diagnosis",
      "self_modify": "wiring_patch"
    },
    "chain_depth": 32,
