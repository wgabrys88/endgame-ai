{
  "schema": "endgame-topology/v1",
  "instance": {"role": "manager"},
  "runtime": {
    "entry": "tui",
    "desktop": {"enabled": true},
    "cli": {
      "goal": {"type": "positional", "nargs": "*", "join": " "},
      "response_limit": {
        "type": "trailing_positive_int",
        "after": "goal",
        "description": "Exit after N LLM responses (smoke/debug mode)"
      },
      "no_desktop": {"type": "flag", "flag": "--no-desktop", "sets": {"runtime.desktop.enabled": false}}
    }
  },
  "startup": {"on_goal": "route_to_slot", "slot": "implementor", "circuit": "unified"},
  "topology": {
    "nodes": [
      {"id": "cli_entry", "type": "entry", "label": "CLI goal + optional N", "drawio": {"x": 40, "y": 40, "w": 180, "h": 50}},
      {"id": "response_limit_gate", "type": "gate", "label": "Stop after N LLM responses", "drawio": {"x": 40, "y": 120, "w": 180, "h": 50, "style": "rhombus;whiteSpace=wrap;html=1;"}},
      {"id": "route_slot", "type": "bus_route", "label": "startup.slot route", "drawio": {"x": 280, "y": 40, "w": 160, "h": 50}},
      {"id": "observe_screen", "type": "desktop_observe", "label": "SCREEN capture / seed", "drawio": {"x": 280, "y": 120, "w": 160, "h": 50}},
      {"id": "build_request", "type": "request_assembly", "label": "USER blocks + SYSTEM prompt", "drawio": {"x": 480, "y": 80, "w": 180, "h": 50}},
      {"id": "llm_call", "type": "llm", "label": "LM Studio chat/completions", "drawio": {"x": 700, "y": 80, "w": 160, "h": 50}},
      {"id": "parse_pipeline", "type": "response_pipeline", "label": "JSON parse + guards", "drawio": {"x": 920, "y": 80, "w": 160, "h": 50}},
      {"id": "feedback_append", "type": "feedback", "label": "reasoning_history append", "drawio": {"x": 920, "y": 180, "w": 160, "h": 50}},
      {"id": "desktop_exec", "type": "desktop_execute", "label": "verbs → actions.py", "drawio": {"x": 1140, "y": 80, "w": 160, "h": 50}},
      {"id": "idle", "type": "idle", "label": "goal_complete / shutdown", "drawio": {"x": 1140, "y": 200, "w": 160, "h": 50}}
    ],
    "edges": [
      {"from": "cli_entry", "to": "response_limit_gate", "on": "args_parsed"},
      {"from": "response_limit_gate", "to": "route_slot", "on": "under_limit"},
      {"from": "route_slot", "to": "observe_screen", "on": "route_open"},
      {"from": "observe_screen", "to": "build_request", "on": "screen_ready"},
      {"from": "build_request", "to": "llm_call", "on": "request_built"},
      {"from": "llm_call", "to": "parse_pipeline", "on": "response_received"},
      {"from": "parse_pipeline", "to": "feedback_append", "on": "unified_acted|unified_cannot|goal_complete"},
      {"from": "parse_pipeline", "to": "desktop_exec", "on": "actions_present"},
      {"from": "desktop_exec", "to": "observe_screen", "on": "unified_acted"},
      {"from": "parse_pipeline", "to": "idle", "on": "goal_complete|limit_reached"},
      {"from": "response_limit_gate", "to": "idle", "on": "limit_reached"}
    ]
  },
  "limits": {
    "max_attempts": 5,
    "reasoning_history_depth": 20,
    "bus_max_records": 200,
    "bus_check_throttle_s": 3,
    "observe_interval_s": 2
  },
  "slots": {
    "implementor": {"enabled": true, "can_desktop": true, "mode": "unified"}
  },
  "circuits": {
    "unified": {
      "prompt": "unified.txt",
      "prompt_swap": [
        {
          "when": [
            "MANAGER.md", "student instance", "peer instance", "manage student",
            "outer controller", "launch the student", "launch student",
            "orchestrate the student", "orchestrate student", "run and manage"
          ],
          "prompt": "manager.txt"
        }
      ]
    }
  },
  "request": {
    "unified": {
      "system": {"source": "prompt_file", "file": "unified.txt", "swap_ref": "circuits.unified.prompt_swap"},
      "user": {
        "separator": "\n",
        "blocks": [
          {"id": "goal", "label": "GOAL", "source": "state.goal", "always": true},
          {"id": "screen", "label": "SCREEN", "source": "state.screen", "empty_template": "{screen_empty}"},
          {"id": "last_error", "label": "LAST ERROR", "source": "state.last_error"},
          {"id": "last_reasoning", "label": "LAST REASONING", "source": "state.last_reasoning"},
          {
            "id": "workspace",
            "label": "WORKSPACE",
            "source": "state.workspace",
            "executor_prefix": "MODE: executor — act on THIS desktop yourself; do not delegate",
            "manager_prefix": "ROLE: {role} — orchestrate peer on desktop (manager prompt active)"
          }
        ]
      }
    }
  },
  "response": {
    "unified": {
      "pipeline": [
        {"step": "parse_json", "from": ["content", "reasoning_content"], "on_fail": "unified_error", "error": "parse_failed: respond with JSON only, no prose"},
        {"step": "extract_fields", "on_fail": "unified_error"},
        {"step": "branch_conclusion"}
      ],
      "guards": {
        "premature_done": {
          "goal_keywords": ["type", "write", "enter text"],
          "required_outcomes": ["write", "typed"],
          "override_outcome": "SYSTEM: goal requires typing but no write was done yet"
        },
        "repeat_block": {"block_if_outcome_contains": "OK"},
        "advance_hints": [
          {"verb": "hotkey", "target_contains": ["win"], "screen_contains": ["run", "combo box \"open", "open:"], "hint": "NEXT REQUIRED: write APPLICATION NAME (e.g. chrome) into Run Open field — NOT hotkey again"},
          {"verb": "hotkey", "target_contains": ["win"], "hint": "NEXT REQUIRED: write app name into Run Open field or focus existing window from SCREEN"},
          {"verb": "write", "screen_contains": ["run", "combo box \"open"], "hint": "NEXT REQUIRED: press enter or click OK to launch the application"},
          {"verb": "write", "screen_contains": ["chrome", "address and search"], "hint": "NEXT REQUIRED: press enter after URL, or write search query in address bar"},
          {"verb": "press", "screen_contains": ["run"], "hint": "NEXT REQUIRED: write APPLICATION NAME in Open field before pressing OK"},
          {"verb": "click", "screen_contains": ["run"], "hint": "NEXT REQUIRED: write APPLICATION NAME in Open field before pressing OK"},
          {"verb": "focus", "hint": "NEXT REQUIRED: open app via win+r → write app name → enter; or click element by [ID] from SCREEN"}
        ],
        "advance_hints_default": "NEXT REQUIRED: different verb+target — prior action already succeeded, read SCREEN"
      }
    }
  },
  "feedback": {
    "reasoning": {
      "depth_from_limits": "reasoning_history_depth",
      "inject_block": "last_reasoning",
      "entry_format": "[attempt] {reasoning} → {outcome}",
      "append_on_events": ["unified_acted", "unified_cannot", "goal_complete"]
    }
  },
  "context": {
    "screen_empty": "(no SCREEN captured — assume bare Windows desktop; Run dialog not visible; no application windows open)",
    "screen_disabled": "(desktop observation disabled — assume bare Windows desktop; Run dialog not visible; no application windows open)"
  },
  "transitions": {
    "default": "unified",
    "unified_acted": "unified",
    "unified_error": "unified",
    "unified_cannot": "unified",
    "goal_complete": "idle",
    "unified_done": "idle"
  },
  "verbs": {
    "click": {"target_field": "target"},
    "write": {"target_field": "target", "value_field": "value"},
    "press": {"key_field": "target"},
    "hotkey": {"key_field": "target"},
    "scroll": {"target_field": "target", "amount_field": "value"},
    "focus": {"title_field": "target"}
  }
}