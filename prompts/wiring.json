{
  "schema": "endgame-topology/v1",
  "instance": {
    "role": "implementor",
    "persona": "implementor",
    "slot": 1,
    "permissions": [
      "desktop_exec",
      "bus_post"
    ]
  },
  "topology": {
    "cycle_start": "goal_inbox",
    "nodes": [
      {
        "id": "goal_inbox",
        "type": "entry",
        "label": "Goal input"
      },
      {
        "id": "planner",
        "type": "planner",
        "label": "Decompose goal \u2192 steps"
      },
      {
        "id": "scheduler",
        "type": "scheduler",
        "label": "Next step or done"
      },
      {
        "id": "bus_check",
        "type": "bus_check",
        "label": "Poll bus for interrupts"
      },
      {
        "id": "observe",
        "type": "observe",
        "label": "Screen capture"
      },
      {
        "id": "act",
        "type": "act",
        "label": "LLM decide + guards + execute"
      },
      {
        "id": "verify",
        "type": "verify",
        "label": "Check step evidence"
      },
      {
        "id": "reflect",
        "type": "reflect",
        "label": "Diagnose + retry/replan"
      },
      {
        "id": "self_modify",
        "type": "self_modify",
        "label": "Alter own wiring"
      },
      {
        "id": "satisfied",
        "type": "satisfied",
        "label": "Rest"
      },
      {
        "id": "bus_post",
        "type": "bus_post",
        "label": "Post telemetry"
      }
    ],
    "edges": [
      {
        "from": "goal_inbox",
        "to": "planner",
        "on": "ready"
      },
      {
        "from": "planner",
        "to": "scheduler",
        "on": "plan_ready"
      },
      {
        "from": "planner",
        "to": "planner",
        "on": "retry_plan"
      },
      {
        "from": "scheduler",
        "to": "bus_check",
        "on": "step_ready"
      },
      {
        "from": "scheduler",
        "to": "bus_post",
        "on": "plan_complete"
      },
      {
        "from": "bus_post",
        "to": "satisfied",
        "on": "posted"
      },
      {
        "from": "bus_check",
        "to": "observe",
        "on": "no_interrupt"
      },
      {
        "from": "bus_check",
        "to": "planner",
        "on": "interrupt"
      },
      {
        "from": "observe",
        "to": "act",
        "on": "screen_ready"
      },
      {
        "from": "act",
        "to": "verify",
        "on": "acted"
      },
      {
        "from": "act",
        "to": "reflect",
        "on": "act_failed"
      },
      {
        "from": "verify",
        "to": "scheduler",
        "on": "step_confirmed"
      },
      {
        "from": "verify",
        "to": "reflect",
        "on": "step_denied"
      },
      {
        "from": "reflect",
        "to": "scheduler",
        "on": "retry"
      },
      {
        "from": "reflect",
        "to": "planner",
        "on": "replan"
      },
      {
        "from": "reflect",
        "to": "self_modify",
        "on": "escalate"
      },
      {
        "from": "self_modify",
        "to": "planner",
        "on": "modified"
      },
      {
        "from": "self_modify",
        "to": "reflect",
        "on": "modify_failed"
      }
    ]
  },
  "reasoning": {
    "store_as": {
      "planner": "planner",
      "unified": "act",
      "verifier": "verify",
      "reflector": "reflect",
      "self_modify": "self_modify"
    },
    "parse_fallback": ["planner", "unified", "verifier", "reflector", "self_modify"],
    "expected_record_type": {
      "planner": "task",
      "unified": "action",
      "verifier": "verdict",
      "reflector": "diagnosis",
      "self_modify": "wiring_patch"
    },
    "chain_depth": 8,
    "clear_on_step_confirm": ["verify", "reflect", "act"]
  },
  "request": {
    "planner": {
      "system": {"file": "planner.txt"},
      "user": {
        "blocks": [
          {"label": "PERSONA", "source": "instance.persona"},
          {"label": "GOAL", "source": "state.goal", "always": true},
          {"label": "SCREEN", "source": "state.screen", "empty_template": "(no screen)"},
          {"label": "REASONING_CHAIN", "source": "reasoning.chain"},
          {"label": "PLANNER_REASONING", "source": "reasoning.planner"}
        ]
      }
    },
    "unified": {
      "system": {"file": "unified.txt"},
      "user": {
        "blocks": [
          {"label": "PERSONA", "source": "instance.persona"},
          {"label": "GOAL", "source": "state.step_goal", "always": true},
          {"label": "SCREEN", "source": "state.screen", "empty_template": "(no screen)"},
          {"label": "VERIFY_REASONING", "source": "reasoning.verify"},
          {"label": "REFLECT_REASONING", "source": "reasoning.reflect"},
          {"label": "REASONING_CHAIN", "source": "reasoning.chain"},
          {"label": "LAST_ERROR", "source": "state.last_error"},
          {"label": "HISTORY", "source": "state.history"}
        ]
      }
    },
    "verifier": {
      "system": {"file": "verifier.txt"},
      "user": {
        "blocks": [
          {"label": "STEP", "source": "state.current_step.description", "always": true},
          {"label": "DONE_WHEN", "source": "state.current_step.done_when"},
          {"label": "SCREEN", "source": "state.screen", "empty_template": "(no screen)"},
          {"label": "LAST_ACTIONS", "source": "state.last_actions"}
        ]
      }
    },
    "reflector": {
      "system": {"file": "reflector.txt"},
      "user": {
        "blocks": [
          {"label": "STEP", "source": "state.current_step.description", "always": true},
          {"label": "DONE_WHEN", "source": "state.current_step.done_when"},
          {"label": "SCREEN", "source": "state.screen", "empty_template": "(no screen)"},
          {"label": "LAST_ACTIONS", "source": "state.last_actions"},
          {"label": "VERIFY_REASONING", "source": "reasoning.verify"}
        ]
      }
    },
    "self_modify": {
      "system": {"file": "self_modify.txt"},
      "user": {
        "blocks": [
          {"label": "GOAL", "source": "state.goal", "always": true},
          {"label": "REASONING_CHAIN", "source": "reasoning.chain"},
          {"label": "REFLECT_REASONING", "source": "reasoning.reflect"},
          {"label": "VERIFY_REASONING", "source": "reasoning.verify"},
          {"label": "LAST_ERROR", "source": "state.last_error"},
          {"label": "HISTORY", "source": "state.history"},
          {"label": "CURRENT_NODES", "source": "topology.nodes"}
        ]
      }
    }
  },
  "circuits": {
    "unified": {
      "prompt": "unified.txt",
      "prompt_swap": [
        {
          "when": [
            "MANAGER.md",
            "student instance",
            "orchestrate the student"
          ],
          "prompt": "manager.txt"
        }
      ]
    }
  },
  "guards": {
    "advance_hints": [
      {
        "verb": "hotkey",
        "target_contains": [
          "win"
        ],
        "screen_contains": [
          "run",
          "open:"
        ],
        "hint": "NEXT REQUIRED: write APPLICATION NAME into Run Open field"
      },
      {
        "verb": "hotkey",
        "target_contains": [
          "win"
        ],
        "hint": "NEXT REQUIRED: write app name into Run Open field or focus existing window"
      },
      {
        "verb": "write",
        "screen_contains": [
          "run",
          "open"
        ],
        "hint": "NEXT REQUIRED: press enter to launch the application"
      },
      {
        "verb": "focus",
        "hint": "NEXT REQUIRED: interact with the focused window content"
      }
    ],
    "advance_hints_default": "NEXT REQUIRED: different action \u2014 prior succeeded, read SCREEN"
  },
  "runtime": {
    "http_port_base": 9077,
    "http_port_slot_offset": true,
    "colony_port_base": 9076,
    "cycle_delay_ms": 300,
    "initial_state": {
      "step": 0,
      "retries": 0,
      "no_desktop": false,
      "history": [],
      "reasoning": {},
      "reasoning_chain": [],
      "planner_retries": 0,
      "replan_count": 0,
      "last_error": ""
    }
  },
  "node_circuits": {
    "planner": "planner",
    "act": "unified",
    "verify": "verifier",
    "reflect": "reflector",
    "self_modify": "self_modify"
  },
  "act": {
    "valid_conclusions": ["EXECUTE", "CANNOT"],
    "reject_conclusions": ["DONE"],
    "verb_normalize": [
      {"from": "press", "to": "hotkey", "when_target_contains": "+"}
    ]
  },
  "moe": {
    "required_permission": "desktop_exec",
    "delegate_keywords": ["open", "click", "type", "write", "launch", "play"],
    "default_exec_slot": 1
  },
  "errors": {
    "parse_failed": "parse_failed: respond with JSON only",
    "act_done_rejected": "DONE is invalid — output EXECUTE with one action; verify node confirms step completion",
    "act_cannot": "CANNOT",
    "act_bad_conclusion": "bad conclusion: {conclusion}",
    "verify_parse_failed": "verify parse failed",
    "reflector_parse_failed": "reflector: parse_failed or wrong record_type — output diagnosis JSON only",
    "planner_parse_failed": "planner: parse_failed — respond with JSON only",
    "planner_empty": "planner: empty plan",
    "self_modify_invalid": "LLM returned invalid patch"
  },
  "limits": {
    "max_attempts": 5,
    "max_replans": 2,
    "max_cycles": 300,
    "history_depth": 10,
    "bus_max": 200,
    "planner_retries": 3
  },
  "verbs": {
    "click": {
      "target_field": "target"
    },
    "write": {
      "target_field": "target",
      "value_field": "value"
    },
    "press": {
      "key_field": "target"
    },
    "hotkey": {
      "key_field": "target"
    },
    "scroll": {
      "target_field": "target",
      "amount_field": "value"
    },
    "focus": {
      "title_field": "target"
    }
  },
  "context": {
    "screen_disabled": "(desktop observation disabled)"
  }
}