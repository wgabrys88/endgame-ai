<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="endgame-ai" agent="endgame-topology/v1" version="1.0" type="device">
  <diagram id="topology" name="topology">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="CLI goal + optional N&#10;(entry)&#10;eg:cli_entry" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3" value="Stop after N LLM responses&#10;(gate)&#10;eg:response_limit_gate" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="4" value="startup.slot route&#10;(bus_route)&#10;eg:route_slot" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="40" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="5" value="SCREEN capture / seed&#10;(desktop_observe)&#10;eg:observe_screen" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="120" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="6" value="USER blocks + SYSTEM prompt&#10;(request_assembly)&#10;eg:build_request" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="7" value="LM Studio chat/completions&#10;(llm)&#10;eg:llm_call" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="8" value="JSON parse + guards&#10;(response_pipeline)&#10;eg:parse_pipeline" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="9" value="reasoning_history append&#10;(feedback)&#10;eg:feedback_append" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="180" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="10" value="verbs → actions.py&#10;(desktop_execute)&#10;eg:desktop_exec" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="11" value="goal_complete / shutdown&#10;(idle)&#10;eg:idle" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="200" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="12" value="args_parsed" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="2" target="3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="13" value="under_limit" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="14" value="route_open" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="15" value="screen_ready" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="16" value="request_built" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="6" target="7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="17" value="response_received" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="7" target="8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="18" value="unified_acted|unified_cannot|goal_complete" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="8" target="9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="19" value="actions_present" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="8" target="10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="20" value="unified_acted" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="10" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="21" value="goal_complete|limit_reached" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="8" target="11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" value="limit_reached" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="3" target="11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="endgame-config" name="_config">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="endgame-json:" style="text;html=1;strokeColor=none;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="2400" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>