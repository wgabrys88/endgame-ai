# ══════════════════════════════════════════════════════════════
# endgame-ai: ALLOWLIST gitignore
# Strategy: deny everything (*), then whitelist tracked sources.
# ══════════════════════════════════════════════════════════════

# Deny all by default
*

# ─── Tracked: Source ──────────────────────────────────────────
!server.py
!desktop.py
!actions.py
!colony.py
!wiring-editor.html



# ─── Tracked: Configuration ──────────────────────────────────
!prompts/
!prompts/wiring.json
!prompts/wiring_relay.json
!prompts/wiring-schema.json
!prompts/model.json
!prompts/model_relay.json

# ─── Tracked: Documentation & Meta ───────────────────────────
!README.md
!logs/
!logs/*.jsonl
!LICENSE
!.gitignore
!.gitattributes

# ─── Explicitly ignored runtime artifacts ─────────────────────
state.json
state.slot*.json
bus.json
comms/
prompts/traces.jsonl
prompts/wiring.backup.json
prompts/wiring.backup.*.json
__pycache__/
*.pyc
*.log
terminals/
mcps/
.cursor/
.grok/
*.tmp