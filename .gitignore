# Whitelist repo: ignore everything unless explicitly allowed.
*

# --- Tracked project files ---
!.gitignore
!.gitattributes
!.env
!AGENTS.md
!README.md
!LICENSE
!CONTRIBUTING.md
!KNOWLEDGE.md
!CHECKLIST.md
!*.py
!prompts/
!prompts/**
!schemas/
!schemas/**
!plugins/
!plugins/**

# --- Build / cache ---
__pycache__/
*.pyc

# --- Runtime (never commit) ---
runtime/
sessions/
events*.jsonl
snapshot.json
respawn.json
goal.txt
pause
*.lock
!HANDOVER.md
