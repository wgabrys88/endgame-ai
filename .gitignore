# Runtime and local-only data stay sealed.
__pycache__/
*.py[cod]
.pytest_cache/
comms/
pids/
state.json
goal.json
*.txt
*.tmp
*.log
request-logs-*.jsonl
notebooklm_exports/

# Secrets and local environment.
.env
.env.*
*.key
*.pem
*.p12
*.pfx

# Local tooling and OS/editor files.
.agents/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
