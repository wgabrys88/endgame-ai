# Source allowlist: ignore everything unless this file explicitly allows it.
*
.*

!.gitattributes
!.gitignore
!LICENSE
!brain.py
!desktop.py
!nodes.py
!organism.py
!stop_check.py
!bus.py
!wiring.json

!brain_transports/
!brain_transports/*.py
!organism_nodes/
!organism_nodes/*.py
!observation/
