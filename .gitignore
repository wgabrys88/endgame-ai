# Whitelist repo: ignore everything unless explicitly allowed below.
*

# --- Tracked project files (clone must include these) ---
!.gitignore
!.gitattributes
!AGENTS.md
!README.md
!LICENSE
!CONTRIBUTING.md
!GROK.md
!EXECUTION_REPORT.md
!*.py
!prompts/
!prompts/**
!schemas/
!schemas/**
!plugins/
!plugins/**

# --- Build / cache ---
__pycache__/
*.pyc

# --- Runtime session artifacts (NEVER commit — preserve locally) ---
# Created by tui.py / log.cleanup_runtime(). Restarting TUI WIPES these.
# Archive before reboot: python forensic_collect.py
runtime/
events*.jsonl
snapshot.json
lessons.jsonl
respawn.json
child_pids.json
goal.txt
pause
gui_mode
*.lock
tmp*.py
report.md
messages.json
mission.json
temp_work_file.txt
disabled.json
status.log
monitor.log
colony_snapshot.json
events_log_files.txt

# --- Forensic archives (local evidence bundles — never ship) ---
forensic_bundle/
forensic_matrix_escape*.zip

# --- Agent spawn scripts at repo root only (not plugins/spawn_coord.py) ---
/spawn*.py

# --- Local junk / session folders (never ship) ---
terminals/
child_workspace/
reactor_colony_data/
session-log.md
*.jpg
*.pngsessions/
