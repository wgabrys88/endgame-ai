# Whitelist repo: ignore everything unless explicitly allowed below.
*

# --- Tracked project files (clone must include these) ---
!.gitignore
!.gitattributes
!AGENTS.md
!README.md
!LICENSE
!CONTRIBUTING.md
!GROK.md
!*.py
!prompts/
!prompts/**
!schemas/
!schemas/**
!plugins/
!plugins/**

# --- Build / cache ---
__pycache__/
*.pyc

# --- Runtime session artifacts (created by tui.py / log.cleanup_runtime) ---
runtime/
events*.jsonl
snapshot.json
lessons.jsonl
respawn.json
child_pids.json
goal.txt
pause
gui_mode
*.lock
tmp*.py

# --- Agent spawn scripts at repo root only (not plugins/spawn_coord.py) ---
/spawn*.py

# --- Local junk / session folders (never ship) ---
terminals/
child_workspace/
reactor_colony_data/
session-log.md
*.jpg
*.png