{
  "type": "json_schema",
  "json_schema": {
    "name": "agent_action",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "observe": {
          "type": "string",
          "minLength": 5,
          "maxLength": 600,
          "description": "Factual summary of current screen state relevant to the instruction."
        },
        "reason": {
          "type": "string",
          "minLength": 5,
          "maxLength": 400,
          "description": "Why these actions advance the instruction."
        },
        "action_1": {
          "type": "object",
          "description": "Primary action to execute.",
          "properties": {
            "verb": {
              "type": "string",
              "enum": ["click", "write", "press", "hotkey", "scroll", "wait", "focus", "read_file", "write_file", "spawn_agent", "cmd", "done", "cleanup"]
            },
            "target": { "type": "string", "minLength": 0, "maxLength": 300 },
            "value": { "type": "string", "minLength": 0, "maxLength": 2000 }
          },
          "required": ["verb", "target", "value"],
          "additionalProperties": false
        },
        "action_2": {
          "type": ["object", "null"],
          "description": "Optional second action. Null if none.",
          "properties": {
            "verb": {
              "type": "string",
              "enum": ["click", "write", "press", "hotkey", "scroll", "wait", "focus", "read_file", "write_file", "spawn_agent", "cmd", "done", "cleanup"]
            },
            "target": { "type": "string", "minLength": 0, "maxLength": 300 },
            "value": { "type": "string", "minLength": 0, "maxLength": 2000 }
          },
          "required": ["verb", "target", "value"],
          "additionalProperties": false
        },
        "action_3": {
          "type": ["object", "null"],
          "description": "Optional third action. Null if none.",
          "properties": {
            "verb": {
              "type": "string",
              "enum": ["click", "write", "press", "hotkey", "scroll", "wait", "focus", "read_file", "write_file", "spawn_agent", "cmd", "done", "cleanup"]
            },
            "target": { "type": "string", "minLength": 0, "maxLength": 300 },
            "value": { "type": "string", "minLength": 0, "maxLength": 2000 }
          },
          "required": ["verb", "target", "value"],
          "additionalProperties": false
        },
        "expect": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500,
          "description": "Specific observable outcome expected after performing the actions."
        },
        "conclusion": {
          "type": "string",
          "enum": ["EXPECTED", "UNEXPECTED"],
          "description": "Judge the PREVIOUS cycle result: does the current screen match what was expected last cycle? EXPECTED if the screen shows the predicted outcome. UNEXPECTED if it does not."
        }
      },
      "required": ["observe", "reason", "action_1", "expect", "conclusion"],
      "additionalProperties": false
    }
  }
}
