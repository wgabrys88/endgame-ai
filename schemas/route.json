{
  "type": "json_schema",
  "json_schema": {
    "name": "route_payload",
    "strict": true,
    "schema": {
      "type": "object",
      "description": "MoE route kind payload — comms_operator gating decision",
      "properties": {
        "to": { "type": "string", "description": "Target persona" },
        "reason": { "type": "string", "minLength": 10 },
        "status": { "type": "string", "enum": ["open", "done", "cancelled"] },
        "goal": { "type": "string" },
        "scores": {
          "type": "object",
          "description": "Softmax gate weights persona->float",
          "additionalProperties": { "type": "number" }
        },
        "escalate": { "type": "boolean" },
        "slot": { "type": "integer", "minimum": 2, "maximum": 5 }
      },
      "required": ["to", "reason", "status"]
    }
  }
}