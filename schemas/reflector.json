{
  "type": "json_schema",
  "json_schema": {
    "name": "self_reflection",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "diagnosis": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "lesson": {
          "type": "string",
          "minLength": 10,
          "maxLength": 300
        },
        "recipient": {
          "type": "string",
          "enum": ["planner", "actor", "verifier", ""]
        }
      },
      "required": ["diagnosis", "lesson", "recipient"],
      "additionalProperties": false
    }
  }
}
