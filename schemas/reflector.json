{
  "type": "json_schema",
  "json_schema": {
    "name": "self_reflection",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["success", "failure"],
          "description": "Assessment of the recent trajectory."
        },
        "diagnosis": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Specific root cause visible in the recent execution context."
        },
        "lesson": {
          "type": "string",
          "minLength": 10,
          "maxLength": 300,
          "description": "One reusable, task-independent lesson extracted from the diagnosis."
        },
        "checklist_rewrite": {
          "type": "array",
          "minItems": 0,
          "maxItems": 10,
          "description": "Replacement remaining checklist only when the current checklist is clearly stuck. Empty means keep current.",
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200
          }
        }
      },
      "required": ["outcome", "diagnosis", "lesson", "checklist_rewrite"],
      "additionalProperties": false
    }
  }
}
