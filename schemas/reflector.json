{
  "type": "json_schema",
  "json_schema": {
    "name": "self_reflection",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["success", "failure"],
          "description": "Overall assessment of recent trajectory."
        },
        "diagnosis": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Root cause of current problems."
        },
        "lesson_1": {
          "type": "string",
          "minLength": 10,
          "maxLength": 300,
          "description": "Primary actionable lesson."
        },
        "lesson_2": {
          "type": "string",
          "minLength": 0,
          "maxLength": 300,
          "description": "Secondary lesson or empty."
        },
        "lesson_3": {
          "type": "string",
          "minLength": 0,
          "maxLength": 300,
          "description": "Tertiary lesson or empty."
        },
        "checklist_rewrite": {
          "type": "array",
          "minItems": 0,
          "maxItems": 10,
          "description": "Replacement checklist if current plan is stuck. Empty array means keep current.",
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200
          }
        },
        "pid_kp": {
          "type": "number",
          "description": "PID proportional gain adjustment. 0 means keep current value. Range 0.1-3.0."
        },
        "pid_ki": {
          "type": "number",
          "description": "PID integral gain adjustment. 0 means keep current value. Range 0.05-1.0."
        },
        "pid_kd": {
          "type": "number",
          "description": "PID derivative gain adjustment. 0 means keep current value. Range 0.5-5.0."
        },
        "actor_prompt_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 2500,
          "description": "Full replacement for prompts/actor.txt or empty."
        },
        "planner_prompt_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 2500,
          "description": "Full replacement for prompts/planner.txt or empty."
        },
        "verifier_prompt_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 2500,
          "description": "Full replacement for prompts/verifier.txt or empty."
        },
        "goal_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 400,
          "description": "Rephrased goal or empty."
        },
        "used_fields": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List all blackboard fields you actually read and used to make this decision."
        }
      },
      "required": ["outcome", "diagnosis", "lesson_1", "lesson_2", "lesson_3", "checklist_rewrite", "pid_kp", "pid_ki", "pid_kd", "actor_prompt_rewrite", "planner_prompt_rewrite", "verifier_prompt_rewrite", "goal_rewrite", "used_fields"],
      "additionalProperties": false
    }
  }
}
