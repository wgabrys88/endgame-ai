{
  "type": "json_schema",
  "json_schema": {
    "name": "reflector_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "diagnosis": {
          "type": "string",
          "minLength": 30,
          "description": "Why stuck, cite TRIGGER stag/pid values"
        },
        "suggestion": {
          "type": "string",
          "minLength": 30,
          "description": "Concrete next approach"
        },
        "rule": {
          "type": "string",
          "description": "Planner rule to append, or empty string if none"
        }
      },
      "required": ["diagnosis", "suggestion", "rule"],
      "additionalProperties": false
    }
  }
}