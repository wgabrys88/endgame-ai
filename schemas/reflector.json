{
  "type": "json_schema",
  "json_schema": {
    "name": "self_reflection",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["success", "failure"],
          "description": "Overall assessment of recent trajectory."
        },
        "diagnosis": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Root cause of current problems."
        },
        "lesson_1": {
          "type": "string",
          "minLength": 10,
          "maxLength": 300,
          "description": "Primary actionable lesson."
        },
        "lesson_2": {
          "type": "string",
          "minLength": 0,
          "maxLength": 300,
          "description": "Secondary lesson or empty."
        },
        "lesson_3": {
          "type": "string",
          "minLength": 0,
          "maxLength": 300,
          "description": "Tertiary lesson or empty."
        },
        "actor_prompt_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 800,
          "description": "Full replacement for prompts/actor.txt or empty."
        },
        "planner_prompt_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 800,
          "description": "Full replacement for prompts/planner.txt or empty."
        },
        "verifier_prompt_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 800,
          "description": "Full replacement for prompts/verifier.txt or empty."
        },
        "goal_rewrite": {
          "type": "string",
          "minLength": 0,
          "maxLength": 400,
          "description": "Rephrased goal or empty."
        }
      },
      "required": ["outcome", "diagnosis", "lesson_1", "lesson_2", "lesson_3", "actor_prompt_rewrite", "planner_prompt_rewrite", "verifier_prompt_rewrite", "goal_rewrite"],
      "additionalProperties": false
    }
  }
}
