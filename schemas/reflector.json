{
  "type": "json_schema",
  "json_schema": {
    "name": "self_reflection",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "diagnosis": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Specific root cause of the stuck pattern."
        },
        "lesson": {
          "type": "string",
          "minLength": 10,
          "maxLength": 300,
          "description": "One reusable, task-independent lesson."
        }
      },
      "required": ["diagnosis", "lesson"],
      "additionalProperties": false
    }
  }
}
