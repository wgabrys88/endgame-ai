{
  "type": "json_schema",
  "json_schema": {
    "name": "agent_action",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "observe": {
          "type": "string",
          "minLength": 100,
          "maxLength": 2000
        },
        "actions": {
          "type": "array",
          "minItems": 0,
          "maxItems": 5,
          "items": {
            "type": "object",
            "properties": {
              "verb": {
                "type": "string",
                "enum": [
                  "click",
                  "write",
                  "press",
                  "hotkey",
                  "scroll",
                  "wait",
                  "focus",
                  "read_file",
                  "write_file",
                  "cmd"
                ]
              },
              "target": {
                "type": "string",
                "minLength": 0,
                "maxLength": 200
              },
              "value": {
                "type": "string",
                "minLength": 0,
                "maxLength": 8000
              }
            },
            "required": [
              "verb",
              "target",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "conclusion": {
          "type": "string",
          "enum": [
            "DONE",
            "EXPECTED",
            "UNEXPECTED"
          ]
        },
        "recipient": {
          "type": "string",
          "enum": [
            "planner",
            "verifier",
            "reflector",
            ""
          ]
        }
      },
      "required": [
        "observe",
        "actions",
        "conclusion",
        "recipient"
      ],
      "additionalProperties": false
    }
  }
}
