{
  "type": "json_schema",
  "json_schema": {
    "name": "agent_action",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "observe": {
          "type": "string",
          "minLength": 5,
          "maxLength": 800,
          "description": "Factual summary of current screen state relevant to the instruction."
        },
        "reason": {
          "type": "string",
          "minLength": 5,
          "maxLength": 400,
          "description": "Why these actions advance the instruction."
        },
        "actions": {
          "type": "array",
          "minItems": 0,
          "maxItems": 5,
          "description": "Actions to execute in sequence.",
          "items": {
            "type": "object",
            "properties": {
              "verb": {
                "type": "string",
                "enum": [
                  "click",
                  "write",
                  "press",
                  "hotkey",
                  "scroll",
                  "wait",
                  "focus",
                  "read_file",
                  "write_file",
                  "spawn_agent",
                  "cmd"
                ]
              },
              "target": {
                "type": "string",
                "minLength": 0,
                "maxLength": 200
              },
              "value": {
                "type": "string",
                "minLength": 0,
                "maxLength": 2000
              }
            },
            "required": [
              "verb",
              "target",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "expect": {
          "type": "string",
          "minLength": 5,
          "maxLength": 400,
          "description": "Observable outcome expected after actions."
        },
        "conclusion": {
          "type": "string",
          "enum": [
            "DONE",
            "EXPECTED",
            "UNEXPECTED"
          ],
          "description": "DONE: current instruction is satisfied and no action is needed. EXPECTED: action can continue. UNEXPECTED: blocked or no match."
        }
      },
      "required": [
        "observe",
        "reason",
        "actions",
        "expect",
        "conclusion"
      ],
      "additionalProperties": false
    }
  }
}
