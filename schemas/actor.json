{
  "type": "json_schema",
  "json_schema": {
    "name": "actor_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "verb": {"type": "string", "enum": ["click", "write", "press", "hotkey", "scroll", "wait", "focus"]},
              "target": {"type": "string"},
              "value": {"type": "string"}
            },
            "required": ["verb", "target", "value"],
            "additionalProperties": false
          }
        },
        "conclusion": {"type": "string", "enum": ["EXECUTE", "DONE", "CANNOT"]}
      },
      "required": ["actions", "conclusion"],
      "additionalProperties": false
    }
  }
}
