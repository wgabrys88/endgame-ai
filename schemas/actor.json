{
  "type": "json_schema",
  "json_schema": {
    "name": "agent_action",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "observe": {
          "type": "string",
          "minLength": 5,
          "maxLength": 800,
          "description": "What is visible on screen right now relevant to the instruction."
        },
        "actions": {
          "type": "array",
          "minItems": 0,
          "maxItems": 5,
          "description": "Actions to execute in order.",
          "items": {
            "type": "object",
            "properties": {
              "verb": {
                "type": "string",
                "enum": ["click", "write", "press", "hotkey", "scroll", "wait", "focus", "read_file", "write_file", "spawn_agent", "cmd"]
              },
              "target": {
                "type": "string",
                "minLength": 0,
                "maxLength": 200
              },
              "value": {
                "type": "string",
                "minLength": 0,
                "maxLength": 2000
              }
            },
            "required": ["verb", "target", "value"],
            "additionalProperties": false
          }
        },
        "conclusion": {
          "type": "string",
          "enum": ["DONE", "EXPECTED", "UNEXPECTED"],
          "description": "DONE: instruction already satisfied. EXPECTED: actions should run. UNEXPECTED: blocked."
        }
      },
      "required": ["observe", "actions", "conclusion"],
      "additionalProperties": false
    }
  }
}
