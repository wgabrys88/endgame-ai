{
  "type": "json_schema",
  "json_schema": {
    "name": "verifier_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "confirmed",
            "denied"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 100,
          "maxLength": 800
        }
      },
      "required": [
        "verdict",
        "evidence"
      ],
      "additionalProperties": false
    }
  }
}
