{
  "type": "json_schema",
  "json_schema": {
    "name": "verifier_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["confirmed", "denied"],
          "description": "confirmed if goal is visibly complete. denied otherwise."
        },
        "evidence": {
          "type": "string",
          "minLength": 5,
          "maxLength": 800,
          "description": "Specific screen state or action results proving the verdict."
        }
      },
      "required": ["verdict", "evidence"],
      "additionalProperties": false
    }
  }
}
