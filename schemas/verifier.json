{
  "type": "json_schema",
  "json_schema": {
    "name": "verifier_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["confirmed", "denied"],
          "description": "'confirmed' if the goal is verifiably complete with clear evidence; 'denied' otherwise."
        },
        "evidence": {
          "type": "string",
          "minLength": 5,
          "maxLength": 800,
          "description": "Concrete screen or state observations supporting the verdict."
        },
        "reason": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500,
          "description": "Explanation of the verdict."
        },
        "suggestion": {
          "type": "string",
          "minLength": 0,
          "maxLength": 400,
          "description": "Brief recovery hint when denied."
        },
        "failure_type": {
          "type": ["string", "null"],
          "enum": ["general", "refusal", "timeout", "parse_error", "action_failed", null],
          "description": "Classification of failure when denied."
        },
        "used_fields": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List all blackboard fields you actually read and used to make this decision."
        }
      },
      "required": ["verdict", "evidence", "reason", "suggestion", "failure_type", "used_fields"],
      "additionalProperties": false
    }
  }
}
