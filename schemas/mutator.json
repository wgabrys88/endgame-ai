{
  "type": "json_schema",
  "json_schema": {
    "name": "mutator_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "action": {"type": "string", "enum": ["write_plugin", "patch_plugin", "none"]},
        "filename": {"type": "string", "minLength": 5},
        "content": {"type": "string", "minLength": 100}
      },
      "required": ["action", "filename", "content"],
      "additionalProperties": false
    }
  }
}
