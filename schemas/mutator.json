{
  "type": "json_schema",
  "json_schema": {
    "name": "mutator_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": ["patch_plugin", "none"],
          "description": "patch_plugin may replace the content of an existing plugins/*.py file only"
        },
        "filename": {
          "type": "string",
          "description": "plugins/foo.py or the literal none"
        },
        "content": {
          "type": "string",
          "description": "Full plugin source with def run(board), or reason when action is none"
        }
      },
      "required": ["action", "filename", "content"],
      "additionalProperties": false
    }
  }
}
