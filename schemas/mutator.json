{
  "type": "json_schema",
  "json_schema": {
    "name": "mutator_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "diagnosis": {
          "type": "string",
          "minLength": 50,
          "maxLength": 500
        },
        "action": {
          "type": "string",
          "enum": ["write_plugin", "patch_plugin", "none"]
        },
        "filename": {
          "type": "string",
          "minLength": 0,
          "maxLength": 100
        },
        "content": {
          "type": "string",
          "minLength": 0,
          "maxLength": 4000
        }
      },
      "required": ["diagnosis", "action", "filename", "content"],
      "additionalProperties": false
    }
  }
}
