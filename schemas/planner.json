{
  "type": "json_schema",
  "json_schema": {
    "name": "planner_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "done"],
          "description": "direct: actor executes next_action. done: goal complete."
        },
        "next_action": {
          "type": "string",
          "minLength": 0,
          "maxLength": 1500,
          "description": "One atomic instruction for the actor. Do NOT combine multiple steps."
        },
        "sequence": {
          "type": "array",
          "minItems": 0,
          "maxItems": 12,
          "description": "Full step-by-step plan. Emit on first call; empty [] on subsequent calls.",
          "items": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300
          }
        }
      },
      "required": ["mode", "next_action", "sequence"],
      "additionalProperties": false
    }
  }
}
