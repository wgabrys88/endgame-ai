{
  "type": "json_schema",
  "json_schema": {
    "name": "planner_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "done"]
        },
        "sequence": {
          "type": "array",
          "minItems": 0,
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 300
          }
        },
        "done_when": {
          "type": "string",
          "minLength": 5,
          "maxLength": 200
        }
      },
      "required": ["mode", "sequence", "done_when"],
      "additionalProperties": false
    }
  }
}
