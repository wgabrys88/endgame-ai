{
  "type": "json_schema",
  "json_schema": {
    "name": "planner_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "mode": {"type": "string", "enum": ["direct", "done"]},
        "sequence": {"type": "array", "items": {"type": "string", "minLength": 200}, "minItems": 1},
        "done_when": {"type": "string", "minLength": 1000}
      },
      "required": ["mode", "sequence", "done_when"],
      "additionalProperties": false
    }
  }
}
