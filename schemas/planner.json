{
  "type": "json_schema",
  "json_schema": {
    "name": "planner_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "done"
          ]
        },
        "sequence": {
          "type": "array",
          "minItems": 0,
          "maxItems": 4,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 140
          }
        },
        "done_when": {
          "type": "string",
          "minLength": 0,
          "maxLength": 140
        }
      },
      "required": [
        "mode",
        "sequence",
        "done_when"
      ],
      "additionalProperties": false
    }
  }
}
