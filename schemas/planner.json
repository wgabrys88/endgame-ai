{
  "type": "json_schema",
  "json_schema": {
    "name": "planner_output",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "done"]
        },
        "next_action": {
          "type": "string",
          "minLength": 0,
          "maxLength": 1500
        },
        "sequence": {
          "type": "array",
          "minItems": 0,
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300
          }
        },
        "recipient": {
          "type": "string",
          "enum": ["actor", "verifier", "reflector", ""]
        }
      },
      "required": ["mode", "next_action", "sequence", "recipient"],
      "additionalProperties": false
    }
  }
}
