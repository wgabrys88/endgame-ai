{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "GROK.md",
    "CONTRIBUTING.md"
  ],
  "default_agent": "build",
  "shell": "powershell",
  "logLevel": "INFO",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "git status": "allow",
      "git branch": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git checkout*": "ask",
      "git push*": "ask",
      "git reset*": "ask",
      "git rebase*": "ask",
      "python -m compileall*": "allow",
      "python *.py": "allow",
      "taskkill*": "ask",
      "rm *": "ask",
      "rmdir*": "ask",
      "*": "ask"
    },
    "task": "allow",
    "external_directory": {
      "C:\\Users\\px-wjt\\AppData\\Local\\Temp\\opencode": "allow",
      "*": "ask"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "compaction": {
    "auto": true,
    "tail_turns": 5,
    "prune": false
  },
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 51200
  }
}
